# =============================================================================
# GwenLand repository root — local-only paths (not published to GitHub)
# =============================================================================
# Tracked at root: gwen-cli/, README.md, LICENSE.txt, .gitignore
# Leading "/" limits patterns to the repository root only.

# -----------------------------------------------------------------------------
# Agent / IDE / local tooling
# -----------------------------------------------------------------------------
/.agents/
/.claude/
/skills-lock.json

# -----------------------------------------------------------------------------
# Local docs, notes, and experiments
# -----------------------------------------------------------------------------
/Issues/
/benchmark/
/New Experimental Formula/
/Testing The Truth Benchmark/

# -----------------------------------------------------------------------------
# Node.js (orphan root wrapper — real package lives in gwen-cli/)
# -----------------------------------------------------------------------------
/node_modules/
/package.json
/pnpm-lock.yaml
/pnpm-workspace.yaml
/turbo.json

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log

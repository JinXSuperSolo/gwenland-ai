//
// glcuda.ptx - hand-authored SIMT kernels for the GwenLand CUDA engine.
//
// ArchGLML_X2 section 16: SIMT-first, warp-shuffle reductions, FP32 accumulation
// everywhere. Hand-written PTX (no nvcc in the toolchain - ADR-004's
// "PTX embedded in binary" option); the driver JIT-compiles this for the
// actual device at module load.
//
// Semantic translation table (Appendix A):
//   gl_gemv_f32          <-> glproc matmul::scalar::run_matvec (decode GEMV)
//   gl_gemv_q8_0         <-> dequant(Q8_0) + f32 GEMV (weights stay quantized
//                            in VRAM; dequantized in registers per element)
//   gl_gemv_t_f32        <-> glproc attention weighted-V sum (column access)
//   gl_rms_norm_f32      <-> glproc ops::rms_norm::scalar::run_into
//   gl_softmax_scale_f32 <-> glproc attention::softmax (scale folded in)
//   gl_silu_mul_f32      <-> glproc ops::silu::scalar::run
//   gl_rope_f32          <-> glproc runner::rope (host supplies cos/sin)
//   gl_add_f32           <-> residual add in glproc runner::step
//   gl_attn_decode_f32   <-> the whole per-head decode-attention loop, fused:
//                            one block per query head does q.k, softmax and the
//                            weighted-V sum in shared memory. Replaces the
//                            gemv+softmax+gemv_t triple launched once per head
//                            (M2.1 fusion: ~3*n_heads launches -> 1 per layer).
//
.version 7.0
.target sm_70
.address_size 64

// ---------------------------------------------------------------------------
// gl_add_f32: y[i] += x[i].  Launch: grid ceil(n/256) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_add_f32(
    .param .u64 p_y,
    .param .u64 p_x,
    .param .u32 p_n
)
{
    .reg .pred %p<2>;
    .reg .b32 %r<8>;
    .reg .f32 %f<4>;
    .reg .b64 %rd<8>;

    ld.param.u64 %rd1, [p_y];
    ld.param.u64 %rd2, [p_x];
    ld.param.u32 %r1, [p_n];
    mov.u32 %r2, %ctaid.x;
    mov.u32 %r3, %ntid.x;
    mov.u32 %r4, %tid.x;
    mad.lo.s32 %r5, %r2, %r3, %r4;
    setp.ge.u32 %p1, %r5, %r1;
    @%p1 bra ADD_DONE;
    cvta.to.global.u64 %rd3, %rd1;
    cvta.to.global.u64 %rd4, %rd2;
    mul.wide.u32 %rd5, %r5, 4;
    add.s64 %rd6, %rd3, %rd5;
    add.s64 %rd7, %rd4, %rd5;
    ld.global.f32 %f1, [%rd6];
    ld.global.f32 %f2, [%rd7];
    add.f32 %f3, %f1, %f2;
    st.global.f32 [%rd6], %f3;
ADD_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_silu_mul_f32: gate[i] = gate[i] / (1 + exp(-gate[i])) * up[i].
// exp via ex2.approx (rel err ~2^-22, far inside the SwiGLU epsilon).
// Launch: grid ceil(n/256) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_silu_mul_f32(
    .param .u64 p_gate,
    .param .u64 p_up,
    .param .u32 p_n
)
{
    .reg .pred %p<2>;
    .reg .b32 %r<8>;
    .reg .f32 %f<10>;
    .reg .b64 %rd<10>;

    ld.param.u64 %rd1, [p_gate];
    ld.param.u64 %rd2, [p_up];
    ld.param.u32 %r1, [p_n];
    mov.u32 %r2, %ctaid.x;
    mov.u32 %r3, %ntid.x;
    mov.u32 %r4, %tid.x;
    mad.lo.s32 %r5, %r2, %r3, %r4;
    setp.ge.u32 %p1, %r5, %r1;
    @%p1 bra SILU_DONE;
    cvta.to.global.u64 %rd3, %rd1;
    cvta.to.global.u64 %rd4, %rd2;
    mul.wide.u32 %rd5, %r5, 4;
    add.s64 %rd6, %rd3, %rd5;
    add.s64 %rd7, %rd4, %rd5;
    ld.global.f32 %f1, [%rd6];          // x = gate[i]
    ld.global.f32 %f2, [%rd7];          // u = up[i]
    mul.f32 %f3, %f1, 0fBFB8AA3B;       // -x * log2(e)
    ex2.approx.f32 %f4, %f3;            // exp(-x)
    add.f32 %f5, %f4, 0f3F800000;       // 1 + exp(-x)
    div.rn.f32 %f6, %f1, %f5;           // silu(x), same op order as glproc
    mul.f32 %f7, %f6, %f2;
    st.global.f32 [%rd6], %f7;
SILU_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_rope_f32: rotate dimension pairs of every head in x [n_heads*head_dim].
// cos/sin are host-computed tables for EVERY position [max_ctx * head_dim/2];
// the host owns transcendental precision (RoPE epsilon is 1e-7; device
// sin.approx cannot honor that). The current position is read from device
// memory (p_pos) so this kernel's launch args never change token-to-token,
// which lets the per-token graph be captured once and replayed (M2.2). The
// row for `pos` starts at cos[pos*half].
// neox = 0: pair (2i, 2i+1);  neox = 1: pair (i, i + half).
// Launch: grid ceil(n_heads*head_dim/2 / 256) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_rope_f32(
    .param .u64 p_x,
    .param .u64 p_cos,
    .param .u64 p_sin,
    .param .u32 p_heads,
    .param .u32 p_head_dim,
    .param .u32 p_neox,
    .param .u64 p_pos
)
{
    .reg .pred %p<3>;
    .reg .b32 %r<20>;
    .reg .f32 %f<12>;
    .reg .b64 %rd<16>;

    ld.param.u64 %rd1, [p_x];
    ld.param.u64 %rd2, [p_cos];
    ld.param.u64 %rd3, [p_sin];
    ld.param.u32 %r1, [p_heads];
    ld.param.u32 %r2, [p_head_dim];
    ld.param.u32 %r3, [p_neox];
    ld.param.u64 %rd14, [p_pos];
    shr.u32 %r4, %r2, 1;                // half = head_dim / 2
    mov.u32 %r5, %ctaid.x;
    mov.u32 %r6, %ntid.x;
    mov.u32 %r7, %tid.x;
    mad.lo.s32 %r8, %r5, %r6, %r7;      // pair index
    mul.lo.s32 %r9, %r1, %r4;           // total pairs
    setp.ge.u32 %p1, %r8, %r9;
    @%p1 bra ROPE_DONE;
    div.u32 %r10, %r8, %r4;             // h
    rem.u32 %r11, %r8, %r4;             // i
    mul.lo.s32 %r12, %r10, %r2;         // base = h * head_dim
    setp.ne.u32 %p2, %r3, 0;
    @%p2 bra ROPE_NEOX;
    shl.b32 %r13, %r11, 1;
    add.s32 %r14, %r12, %r13;           // a = base + 2i
    add.s32 %r15, %r14, 1;              // b = a + 1
    bra ROPE_IDX_DONE;
ROPE_NEOX:
    add.s32 %r14, %r12, %r11;           // a = base + i
    add.s32 %r15, %r14, %r4;            // b = a + half
ROPE_IDX_DONE:
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    // table index = pos*half + i  (pos read from device memory)
    cvta.to.global.u64 %rd15, %rd14;
    ld.global.u32 %r16, [%rd15];        // pos
    mul.lo.s32 %r17, %r16, %r4;         // pos * half
    add.s32 %r18, %r17, %r11;           // pos*half + i
    mul.wide.u32 %rd7, %r18, 4;
    add.s64 %rd8, %rd5, %rd7;
    add.s64 %rd9, %rd6, %rd7;
    ld.global.f32 %f1, [%rd8];          // cos[pos*half + i]
    ld.global.f32 %f2, [%rd9];          // sin[pos*half + i]
    mul.wide.u32 %rd10, %r14, 4;
    add.s64 %rd11, %rd4, %rd10;
    mul.wide.u32 %rd12, %r15, 4;
    add.s64 %rd13, %rd4, %rd12;
    ld.global.f32 %f3, [%rd11];         // x0
    ld.global.f32 %f4, [%rd13];         // x1
    // Same operation order as glproc's rope: mul, mul, sub / mul, mul, add -
    // bit-identical rounding given identical cos/sin inputs.
    mul.f32 %f5, %f3, %f1;
    mul.f32 %f6, %f4, %f2;
    sub.f32 %f7, %f5, %f6;              // x0*cos - x1*sin
    mul.f32 %f8, %f3, %f2;
    mul.f32 %f9, %f4, %f1;
    add.f32 %f10, %f8, %f9;             // x0*sin + x1*cos
    st.global.f32 [%rd11], %f7;
    st.global.f32 [%rd13], %f10;
ROPE_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_gemv_f32: y = W @ x, W row-major [out_dim, in_dim] (decode GEMV).
// One warp per output row (section 16 kernel inventory): lane l accumulates
// k = l, l+32, ... (coalesced across the row), then a warp-shuffle tree
// reduces - deterministic order for a fixed warp size, FP32 accumulation.
// Launch: grid (out_dim) x 32 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_gemv_f32(
    .param .u64 p_w,
    .param .u64 p_x,
    .param .u64 p_y,
    .param .u32 p_out,
    .param .u32 p_in
)
{
    .reg .pred %p<4>;
    .reg .b32 %r<8>;
    .reg .f32 %f<8>;
    .reg .b64 %rd<16>;

    ld.param.u64 %rd1, [p_w];
    ld.param.u64 %rd2, [p_x];
    ld.param.u64 %rd3, [p_y];
    ld.param.u32 %r1, [p_out];
    ld.param.u32 %r2, [p_in];
    mov.u32 %r3, %ctaid.x;              // row
    setp.ge.u32 %p1, %r3, %r1;
    @%p1 bra GEMV_DONE;
    mov.u32 %r4, %tid.x;                // lane
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    mul.wide.u32 %rd7, %r3, %r2;        // row * in_dim
    shl.b64 %rd8, %rd7, 2;
    add.s64 %rd9, %rd4, %rd8;           // W row base
    mul.wide.u32 %rd10, %r4, 4;
    add.s64 %rd11, %rd9, %rd10;         // w ptr = row base + lane*4
    add.s64 %rd12, %rd5, %rd10;         // x ptr = x + lane*4
    mov.f32 %f1, 0f00000000;            // FP32 accumulator
    mov.u32 %r5, %r4;                   // k = lane
GEMV_LOOP:
    setp.ge.u32 %p2, %r5, %r2;
    @%p2 bra GEMV_REDUCE;
    ld.global.f32 %f2, [%rd11];
    ld.global.f32 %f3, [%rd12];
    fma.rn.f32 %f1, %f2, %f3, %f1;
    add.s32 %r5, %r5, 32;
    add.s64 %rd11, %rd11, 128;
    add.s64 %rd12, %rd12, 128;
    bra GEMV_LOOP;
GEMV_REDUCE:
    // Warp-shuffle tree. shfl.sync.*.b32 moves *bit* registers, so the f32
    // accumulator is reinterpreted through a .b32 temp (%r6) each step.
    mov.b32 %r6, %f1;
    shfl.sync.down.b32 %r7, %r6, 16, 31, 0xffffffff;
    mov.b32 %f4, %r7;
    add.f32 %f1, %f1, %f4;
    mov.b32 %r6, %f1;
    shfl.sync.down.b32 %r7, %r6, 8, 31, 0xffffffff;
    mov.b32 %f4, %r7;
    add.f32 %f1, %f1, %f4;
    mov.b32 %r6, %f1;
    shfl.sync.down.b32 %r7, %r6, 4, 31, 0xffffffff;
    mov.b32 %f4, %r7;
    add.f32 %f1, %f1, %f4;
    mov.b32 %r6, %f1;
    shfl.sync.down.b32 %r7, %r6, 2, 31, 0xffffffff;
    mov.b32 %f4, %r7;
    add.f32 %f1, %f1, %f4;
    mov.b32 %r6, %f1;
    shfl.sync.down.b32 %r7, %r6, 1, 31, 0xffffffff;
    mov.b32 %f4, %r7;
    add.f32 %f1, %f1, %f4;
    setp.ne.u32 %p3, %r4, 0;
    @%p3 bra GEMV_DONE;
    mul.wide.u32 %rd13, %r3, 4;
    add.s64 %rd14, %rd6, %rd13;
    st.global.f32 [%rd14], %f1;
GEMV_DONE:
    ret;
}

//// ---------------------------------------------------------------------------
// gl_gemv_q8_0: y = W @ x with W in GGML Q8_0 blocks, PADDED to 36 B:
// f16 scale d + 2 bytes padding + 32 signed bytes; weight = d * q.
// Weights stay quantized in VRAM and are perfectly 4-byte aligned due to
// the 2-byte padding injected by the loader.
// One warp per 4 rows (Thread Coarsening to save X bandwidth); 
// lane l owns element l of every block, so per block:
// acc += (d * q[l]) * x[b*32 + l], FP32 accumulation throughout.
// in_dim must be a multiple of 32.
// Launch: grid (out_dim / 4) x 32 threads.
// ---------------------------------------------------------------------------

.visible .entry gl_quantize_q8(
    .param .u64 p_x,
    .param .u64 p_qs,
    .param .u64 p_scales,
    .param .u32 p_n
)
{
    .reg .pred %p<4>;
    .reg .b32 %r<10>;
    .reg .f32 %f<10>;
    .reg .b64 %rd<15>;

    ld.param.u64 %rd1, [p_x];
    ld.param.u64 %rd2, [p_qs];
    ld.param.u64 %rd3, [p_scales];
    ld.param.u32 %r1, [p_n];
    
    mov.u32 %r2, %ctaid.x;
    mov.u32 %r3, %ntid.x;
    mov.u32 %r4, %tid.x;
    mad.lo.s32 %r5, %r2, %r3, %r4;
    setp.ge.u32 %p1, %r5, %r1;
    @%p1 bra QUANT_DONE;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32 %rd5, %r5, 4;
    add.s64 %rd6, %rd4, %rd5;
    ld.global.f32 %f1, [%rd6];

    abs.f32 %f2, %f1;

    shfl.sync.down.b32 %f3, %f2, 16, 31, 0xffffffff;
    max.f32 %f2, %f2, %f3;
    shfl.sync.down.b32 %f3, %f2, 8, 31, 0xffffffff;
    max.f32 %f2, %f2, %f3;
    shfl.sync.down.b32 %f3, %f2, 4, 31, 0xffffffff;
    max.f32 %f2, %f2, %f3;
    shfl.sync.down.b32 %f3, %f2, 2, 31, 0xffffffff;
    max.f32 %f2, %f2, %f3;
    shfl.sync.down.b32 %f3, %f2, 1, 31, 0xffffffff;
    max.f32 %f2, %f2, %f3;

    shfl.sync.idx.b32 %f4, %f2, 0, 31, 0xffffffff;

    div.rn.f32 %f5, %f4, 127.0;
    
    mov.f32 %f6, 0f00000000;
    setp.eq.f32 %p2, %f5, %f6;
    @%p2 bra QUANT_STORE;
    rcp.rn.f32 %f6, %f5;

QUANT_STORE:
    mul.rn.f32 %f7, %f1, %f6;
    cvt.rni.s32.f32 %r6, %f7;

    min.s32 %r6, %r6, 127;
    max.s32 %r6, %r6, -128;
    cvt.s8.s32 %r7, %r6;

    cvta.to.global.u64 %rd7, %rd2;
    mul.wide.u32 %rd8, %r5, 1;
    add.s64 %rd9, %rd7, %rd8;
    st.global.u8 [%rd9], %r7;

    setp.ne.u32 %p3, %r4, 0;
    @%p3 bra QUANT_DONE;
    cvta.to.global.u64 %rd10, %rd3;
    mov.u32 %r8, %ctaid.x;
    mul.wide.u32 %rd11, %r8, 4;
    add.s64 %rd12, %rd10, %rd11;
    st.global.f32 [%rd12], %f5;

QUANT_DONE:
    ret;
}

.visible .entry gl_gemv_q8_0(
    .param .u64 p_w,
    .param .u64 p_x_qs,
    .param .u64 p_x_scales,
    .param .u64 p_y,
    .param .u32 p_out,
    .param .u32 p_in
)
{
    .reg .pred %p<6>;
    .reg .b16 %h<6>;
    .reg .b32 %r<50>;
    .reg .f32 %f<30>;
    .reg .b64 %rd<40>;

    .reg .b32 %r3_0, %r3_1, %r3_2, %r3_3;
    .reg .b64 %rd_x_scales;
    .reg .b64 %rd7_0, %rd7_1, %rd7_2, %rd7_3;
    .reg .b64 %rd15_0, %rd15_1, %rd15_2, %rd15_3;
    .reg .b64 %rd17_0, %rd17_1, %rd17_2, %rd17_3;
    .reg .b64 %rd19_0, %rd19_1, %rd19_2, %rd19_3;
    .reg .b64 %rd8_0, %rd8_1, %rd8_2, %rd8_3;
    .reg .b64 %rd12_0, %rd12_1, %rd12_2, %rd12_3;
    .reg .f32 %f1_0, %f1_1, %f1_2, %f1_3;
    .reg .f32 %f2_0, %f2_1, %f2_2, %f2_3;
    .reg .b16 %h1_0, %h1_1, %h1_2, %h1_3;
    .reg .b32 %r8_0, %r8_1, %r8_2, %r8_3;
    .reg .f32 %f3_0, %f3_1, %f3_2, %f3_3;
    .reg .f32 %f_x_scale;
    .reg .b32 %q32_0, %q32_1, %q32_2, %q32_3;
    .reg .b32 %xq32_0;

    ld.param.u64 %rd1, [p_w];
    ld.param.u64 %rd2, [p_x_qs];
    ld.param.u64 %rd_x_scales, [p_x_scales];
    ld.param.u64 %rd3, [p_y];
    ld.param.u32 %r1, [p_out];
    ld.param.u32 %r2, [p_in];
    .reg .b32 %warp_id, %global_warp, %lane;
    mov.u32 %r3, %ctaid.x;              // row block
    mov.u32 %r4, %tid.x;                // thread index (0-127)
    
    shr.u32 %warp_id, %r4, 5;           // warp_id = tid.x / 32
    and.b32 %lane, %r4, 31;             // lane = tid.x % 32
    mov.u32 %r4, %lane;                 // r4 is now lane (0-31)

    mul.lo.s32 %global_warp, %r3, 4;    // assuming 4 warps per block
    add.s32 %global_warp, %global_warp, %warp_id;

    mul.lo.s32 %r3_0, %global_warp, 4;  // row_0 = global_warp * 4
    setp.ge.u32 %p1, %r3_0, %r1;
    @%p1 bra GEMVQ8_DONE;
    
    add.s32 %r3_1, %r3_0, 1;
    add.s32 %r3_2, %r3_0, 2;
    add.s32 %r3_3, %r3_0, 3;
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    shr.u32 %r5, %r2, 5;                // n_blocks = in_dim / 32
    shr.u32 %r20, %r5, 2;               // n_blocks_4

    shr.u32 %r21, %r4, 3;               // g = lane / 8
    and.b32 %r22, %r4, 7;               // l = lane % 8

    mul.lo.s32 %r6, %r5, 36;            // row bytes (now 36 * n_blocks)
    
    mul.wide.u32 %rd7_0, %r3_0, %r6;
    add.s64 %rd15_0, %rd4, %rd7_0;
    mul.wide.u32 %rd7_1, %r3_1, %r6;
    add.s64 %rd15_1, %rd4, %rd7_1;
    mul.wide.u32 %rd7_2, %r3_2, %r6;
    add.s64 %rd15_2, %rd4, %rd7_2;
    mul.wide.u32 %rd7_3, %r3_3, %r6;
    add.s64 %rd15_3, %rd4, %rd7_3;
    
    mul.lo.s32 %r23, %r21, 36;
    cvt.u64.u32 %rd16, %r23;
    add.s64 %rd17_0, %rd15_0, %rd16;    // scale ptr 0
    add.s64 %rd17_1, %rd15_1, %rd16;
    add.s64 %rd17_2, %rd15_2, %rd16;
    add.s64 %rd17_3, %rd15_3, %rd16;
    
    mul.lo.s32 %r24, %r22, 4;
    add.s32 %r25, %r23, %r24;
    add.s32 %r25, %r25, 4;              // qs start at offset 4
    cvt.u64.u32 %rd18, %r25;
    add.s64 %rd19_0, %rd15_0, %rd18;    // qs ptr 0
    add.s64 %rd19_1, %rd15_1, %rd18;
    add.s64 %rd19_2, %rd15_2, %rd18;
    add.s64 %rd19_3, %rd15_3, %rd18;
    
    shl.b32 %r26, %r21, 5;              // g * 32
    shl.b32 %r27, %r22, 2;              // l * 4
    add.s32 %r28, %r26, %r27;
    cvt.u64.u32 %rd20, %r28;
    add.s64 %rd21, %rd5, %rd20;         // p_x_qs_current

    shl.b32 %r29, %r21, 2;              // g * 4
    cvt.u64.u32 %rd22, %r29;
    cvta.to.global.u64 %rd_x_scales, %rd_x_scales;
    add.s64 %rd23, %rd_x_scales, %rd22; // p_x_scales_current         // x4 ptr

    mov.f32 %f1_0, 0f00000000;          // FP32 acc 0
    mov.f32 %f1_1, 0f00000000;          // FP32 acc 1
    mov.f32 %f1_2, 0f00000000;          // FP32 acc 2
    mov.f32 %f1_3, 0f00000000;          // FP32 acc 3
    mov.u32 %r7, 0;                     // block index

GEMVQ8_LOOP4:
    setp.ge.u32 %p2, %r7, %r20;
    @%p2 bra GEMVQ8_TAIL_INIT;
    
    ld.global.u32 %xq32_0, [%rd21];
    ld.global.f32 %f_x_scale, [%rd23];
    
    // ROW 0
    ld.global.u16 %h1_0, [%rd17_0];
    cvt.f32.f16 %f2_0, %h1_0;
    ld.global.u32 %q32_0, [%rd19_0];
    dp4a.s32.s32 %r30, %q32_0, %xq32_0, 0;
    cvt.rn.f32.s32 %f14, %r30;
    mul.rn.f32 %f18, %f2_0, %f_x_scale;
    fma.rn.f32 %f1_0, %f14, %f18, %f1_0;

    // ROW 1
    ld.global.u16 %h1_1, [%rd17_1];
    cvt.f32.f16 %f2_1, %h1_1;
    ld.global.u32 %q32_1, [%rd19_1];
    dp4a.s32.s32 %r30, %q32_1, %xq32_0, 0;
    cvt.rn.f32.s32 %f14, %r30;
    mul.rn.f32 %f18, %f2_1, %f_x_scale;
    fma.rn.f32 %f1_1, %f14, %f18, %f1_1;

    // ROW 2
    ld.global.u16 %h1_2, [%rd17_2];
    cvt.f32.f16 %f2_2, %h1_2;
    ld.global.u32 %q32_2, [%rd19_2];
    dp4a.s32.s32 %r30, %q32_2, %xq32_0, 0;
    cvt.rn.f32.s32 %f14, %r30;
    mul.rn.f32 %f18, %f2_2, %f_x_scale;
    fma.rn.f32 %f1_2, %f14, %f18, %f1_2;

    // ROW 3
    ld.global.u16 %h1_3, [%rd17_3];
    cvt.f32.f16 %f2_3, %h1_3;
    ld.global.u32 %q32_3, [%rd19_3];
    dp4a.s32.s32 %r30, %q32_3, %xq32_0, 0;
    cvt.rn.f32.s32 %f14, %r30;
    mul.rn.f32 %f18, %f2_3, %f_x_scale;
    fma.rn.f32 %f1_3, %f14, %f18, %f1_3;
    
    add.s64 %rd17_0, %rd17_0, 144;
    add.s64 %rd17_1, %rd17_1, 144;
    add.s64 %rd17_2, %rd17_2, 144;
    add.s64 %rd17_3, %rd17_3, 144;
    add.s64 %rd19_0, %rd19_0, 144;
    add.s64 %rd19_1, %rd19_1, 144;
    add.s64 %rd19_2, %rd19_2, 144;
    add.s64 %rd19_3, %rd19_3, 144;
    add.s64 %rd21, %rd21, 128;
    add.s64 %rd23, %rd23, 16;
    add.s32 %r7, %r7, 1;
    bra GEMVQ8_LOOP4;

GEMVQ8_TAIL_INIT:
    and.b32 %r37, %r5, 3;
    setp.eq.u32 %p4, %r37, 0;
    @%p4 bra GEMVQ8_REDUCE;
    
    shl.b32 %r7, %r20, 2;
    mul.lo.s32 %r38, %r7, 36;
    cvt.u64.u32 %rd22, %r38;
    add.s64 %rd8_0, %rd15_0, %rd22;
    add.s64 %rd8_1, %rd15_1, %rd22;
    add.s64 %rd8_2, %rd15_2, %rd22;
    add.s64 %rd8_3, %rd15_3, %rd22;
    
    cvt.u64.u32 %rd23, %r4;
    add.s64 %rd12_0, %rd8_0, %rd23;
    add.s64 %rd12_0, %rd12_0, 4;
    add.s64 %rd12_1, %rd8_1, %rd23;
    add.s64 %rd12_1, %rd12_1, 4;
    add.s64 %rd12_2, %rd8_2, %rd23;
    add.s64 %rd12_2, %rd12_2, 4;
    add.s64 %rd12_3, %rd8_3, %rd23;
    add.s64 %rd12_3, %rd12_3, 4;
    
    .reg .b64 %rd_x_scales_tail, %rd_x_scales_offset;
    shl.b32 %r39, %r7, 5;
    add.s32 %r39, %r39, %r4;
    cvt.u64.u32 %rd24, %r39;
    add.s64 %rd10, %rd5, %rd24;         // x_qs tail ptr
    
    cvt.u64.u32 %rd_x_scales_offset, %r7;
    shl.b64 %rd_x_scales_offset, %rd_x_scales_offset, 2;
    add.s64 %rd_x_scales_tail, %rd_x_scales, %rd_x_scales_offset;

GEMVQ8_TAIL_LOOP:
    setp.ge.u32 %p5, %r7, %r5;
    @%p5 bra GEMVQ8_REDUCE;
    
    .reg .s8 %rx_tail;
    .reg .s32 %rx_tail_32;
    .reg .f32 %f_x_scale_tail, %f4_int;
    ld.global.s8 %rx_tail, [%rd10];
    ld.global.f32 %f_x_scale_tail, [%rd_x_scales_tail];
    cvt.s32.s8 %rx_tail_32, %rx_tail;
    cvt.rn.f32.s32 %f4_int, %rx_tail_32;
    mul.rn.f32 %f4, %f4_int, %f_x_scale_tail;
    
    ld.global.u16 %h1_0, [%rd8_0];
    cvt.f32.f16 %f2_0, %h1_0;
    ld.global.s8 %r8_0, [%rd12_0];
    cvt.rn.f32.s32 %f3_0, %r8_0;
    mul.rn.f32 %f5, %f2_0, %f3_0;
    fma.rn.f32 %f1_0, %f5, %f4, %f1_0;

    ld.global.u16 %h1_1, [%rd8_1];
    cvt.f32.f16 %f2_1, %h1_1;
    ld.global.s8 %r8_1, [%rd12_1];
    cvt.rn.f32.s32 %f3_1, %r8_1;
    mul.rn.f32 %f5, %f2_1, %f3_1;
    fma.rn.f32 %f1_1, %f5, %f4, %f1_1;

    ld.global.u16 %h1_2, [%rd8_2];
    cvt.f32.f16 %f2_2, %h1_2;
    ld.global.s8 %r8_2, [%rd12_2];
    cvt.rn.f32.s32 %f3_2, %r8_2;
    mul.rn.f32 %f5, %f2_2, %f3_2;
    fma.rn.f32 %f1_2, %f5, %f4, %f1_2;

    ld.global.u16 %h1_3, [%rd8_3];
    cvt.f32.f16 %f2_3, %h1_3;
    ld.global.s8 %r8_3, [%rd12_3];
    cvt.rn.f32.s32 %f3_3, %r8_3;
    mul.rn.f32 %f5, %f2_3, %f3_3;
    fma.rn.f32 %f1_3, %f5, %f4, %f1_3;

    add.s32 %r7, %r7, 1;
    add.s64 %rd8_0, %rd8_0, 36;
    add.s64 %rd8_1, %rd8_1, 36;
    add.s64 %rd8_2, %rd8_2, 36;
    add.s64 %rd8_3, %rd8_3, 36;
    add.s64 %rd12_0, %rd12_0, 36;
    add.s64 %rd12_1, %rd12_1, 36;
    add.s64 %rd12_2, %rd12_2, 36;
    add.s64 %rd12_3, %rd12_3, 36;
    add.s64 %rd10, %rd10, 32;
    add.s64 %rd_x_scales_tail, %rd_x_scales_tail, 4;
    bra GEMVQ8_TAIL_LOOP;

GEMVQ8_REDUCE:
    mov.b32 %r9, %f1_0; shfl.sync.down.b32 %r10, %r9, 16, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_0, %f1_0, %f6; mov.b32 %r9, %f1_0;
    shfl.sync.down.b32 %r10, %r9, 8, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_0, %f1_0, %f6; mov.b32 %r9, %f1_0;
    shfl.sync.down.b32 %r10, %r9, 4, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_0, %f1_0, %f6; mov.b32 %r9, %f1_0;
    shfl.sync.down.b32 %r10, %r9, 2, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_0, %f1_0, %f6; mov.b32 %r9, %f1_0;
    shfl.sync.down.b32 %r10, %r9, 1, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_0, %f1_0, %f6;
    
    mov.b32 %r9, %f1_1; shfl.sync.down.b32 %r10, %r9, 16, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_1, %f1_1, %f6; mov.b32 %r9, %f1_1;
    shfl.sync.down.b32 %r10, %r9, 8, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_1, %f1_1, %f6; mov.b32 %r9, %f1_1;
    shfl.sync.down.b32 %r10, %r9, 4, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_1, %f1_1, %f6; mov.b32 %r9, %f1_1;
    shfl.sync.down.b32 %r10, %r9, 2, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_1, %f1_1, %f6; mov.b32 %r9, %f1_1;
    shfl.sync.down.b32 %r10, %r9, 1, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_1, %f1_1, %f6;

    mov.b32 %r9, %f1_2; shfl.sync.down.b32 %r10, %r9, 16, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_2, %f1_2, %f6; mov.b32 %r9, %f1_2;
    shfl.sync.down.b32 %r10, %r9, 8, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_2, %f1_2, %f6; mov.b32 %r9, %f1_2;
    shfl.sync.down.b32 %r10, %r9, 4, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_2, %f1_2, %f6; mov.b32 %r9, %f1_2;
    shfl.sync.down.b32 %r10, %r9, 2, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_2, %f1_2, %f6; mov.b32 %r9, %f1_2;
    shfl.sync.down.b32 %r10, %r9, 1, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_2, %f1_2, %f6;

    mov.b32 %r9, %f1_3; shfl.sync.down.b32 %r10, %r9, 16, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_3, %f1_3, %f6; mov.b32 %r9, %f1_3;
    shfl.sync.down.b32 %r10, %r9, 8, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_3, %f1_3, %f6; mov.b32 %r9, %f1_3;
    shfl.sync.down.b32 %r10, %r9, 4, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_3, %f1_3, %f6; mov.b32 %r9, %f1_3;
    shfl.sync.down.b32 %r10, %r9, 2, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_3, %f1_3, %f6; mov.b32 %r9, %f1_3;
    shfl.sync.down.b32 %r10, %r9, 1, 31, 0xffffffff;
    mov.b32 %f6, %r10; add.f32 %f1_3, %f1_3, %f6;

    setp.ne.u32 %p3, %r4, 0;
    @%p3 bra GEMVQ8_DONE;

    // Write Row 0
    mul.wide.u32 %rd13, %r3_0, 4;
    add.s64 %rd14, %rd6, %rd13;
    st.global.f32 [%rd14], %f1_0;

    // Write Row 1
    mul.wide.u32 %rd13, %r3_1, 4;
    add.s64 %rd14, %rd6, %rd13;
    st.global.f32 [%rd14], %f1_1;

    // Write Row 2
    mul.wide.u32 %rd13, %r3_2, 4;
    add.s64 %rd14, %rd6, %rd13;
    st.global.f32 [%rd14], %f1_2;

    // Write Row 3
    mul.wide.u32 %rd13, %r3_3, 4;
    add.s64 %rd14, %rd6, %rd13;
    st.global.f32 [%rd14], %f1_3;

GEMVQ8_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_gemv_q8_0_soa: y = W @ x, Q8_0 weights in STRUCTURE-OF-ARRAYS layout.
//   p_wqs : contiguous int8 weights [out_dim * in_dim]
//   p_wsc : contiguous f16 block scales [out_dim * (in_dim/32)]
//   p_xqs : int8 quantized activation [in_dim]
//   p_xsc : f32 activation block scales [in_dim/32]
//   p_y   : f32 output [out_dim]
// One warp per output row. Each iteration the 32 lanes read 128 CONTIGUOUS qs
// bytes (4 blocks) -> one coalesced 128-byte transaction, no padding, no
// interleaved scales (the AoS gl_gemv_q8_0 wastes ~23% BW on those). dp4a on
// 4 int8/lane; per-block scales folded in f32; 32-lane shuffle reduction.
// Lanes 0-7 cover block 0, 8-15 block 1, ... (block-in-group = lane/8).
// Launch: grid ceil(out_dim / (ntid/32)) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_gemv_q8_0_soa(
    .param .u64 p_wqs,
    .param .u64 p_wsc,
    .param .u64 p_xqs,
    .param .u64 p_xsc,
    .param .u64 p_y,
    .param .u32 p_out,
    .param .u32 p_in
)
{
    .reg .pred %p<5>;
    .reg .b16 %h<3>;
    .reg .b32 %r<40>;
    .reg .f32 %f<12>;
    .reg .b64 %rd<40>;

    ld.param.u64 %rd1, [p_wqs];
    ld.param.u64 %rd2, [p_wsc];
    ld.param.u64 %rd3, [p_xqs];
    ld.param.u64 %rd4, [p_xsc];
    ld.param.u64 %rd5, [p_y];
    ld.param.u32 %r1, [p_out];
    ld.param.u32 %r2, [p_in];

    mov.u32 %r3, %tid.x;
    shr.u32 %r4, %r3, 5;                 // warp_id
    and.b32 %r5, %r3, 31;                // lane
    mov.u32 %r6, %ntid.x;
    shr.u32 %r7, %r6, 5;                 // warps per block
    mov.u32 %r8, %ctaid.x;
    mad.lo.s32 %r9, %r8, %r7, %r4;       // output row
    setp.ge.u32 %p1, %r9, %r1;
    @%p1 bra SOA_DONE;

    cvta.to.global.u64 %rd6, %rd1;
    cvta.to.global.u64 %rd7, %rd2;
    cvta.to.global.u64 %rd8, %rd3;
    cvta.to.global.u64 %rd9, %rd4;

    shr.u32 %r10, %r2, 5;                // n_blocks = in_dim / 32

    mul.wide.u32 %rd10, %r9, %r2;        // wqs row base = row * in_dim
    add.s64 %rd11, %rd6, %rd10;
    mul.wide.u32 %rd12, %r9, %r10;       // wsc row base = row * n_blocks
    shl.b64 %rd12, %rd12, 1;             // * 2 (f16)
    add.s64 %rd13, %rd7, %rd12;

    shl.b32 %r11, %r5, 2;                // lane * 4 (byte offset in group)
    cvt.u64.u32 %rd14, %r11;
    add.s64 %rd15, %rd11, %rd14;         // wqs lane ptr
    add.s64 %rd16, %rd8, %rd14;          // xqs lane ptr
    shr.u32 %r12, %r5, 3;                // block-in-group = lane / 8 (0..3)
    cvt.u64.u32 %rd17, %r12;
    shl.b64 %rd18, %rd17, 1;
    add.s64 %rd19, %rd13, %rd18;         // wsc block ptr
    shl.b64 %rd20, %rd17, 2;
    add.s64 %rd21, %rd9, %rd20;          // xsc block ptr

    mov.f32 %f1, 0f00000000;             // accumulator
    shr.u32 %r13, %r10, 2;               // n_groups = n_blocks / 4
    mov.u32 %r14, 0;

SOA_LOOP:
    setp.ge.u32 %p2, %r14, %r13;
    @%p2 bra SOA_TAIL;

    ld.global.u32 %r15, [%rd15];
    ld.global.u32 %r16, [%rd16];
    dp4a.s32.s32 %r17, %r15, %r16, 0;
    cvt.rn.f32.s32 %f2, %r17;
    ld.global.u16 %h1, [%rd19];
    cvt.f32.f16 %f3, %h1;
    ld.global.f32 %f4, [%rd21];
    mul.rn.f32 %f5, %f3, %f4;
    fma.rn.f32 %f1, %f2, %f5, %f1;

    add.s64 %rd15, %rd15, 128;
    add.s64 %rd16, %rd16, 128;
    add.s64 %rd19, %rd19, 8;             // 4 blocks * 2 B
    add.s64 %rd21, %rd21, 16;            // 4 blocks * 4 B
    add.s32 %r14, %r14, 1;
    bra SOA_LOOP;

SOA_TAIL:
    and.b32 %r18, %r10, 3;               // remaining blocks (n_blocks % 4)
    setp.lt.u32 %p3, %r12, %r18;         // this lane's block within remainder?
    @!%p3 bra SOA_REDUCE;
    ld.global.u32 %r15, [%rd15];
    ld.global.u32 %r16, [%rd16];
    dp4a.s32.s32 %r17, %r15, %r16, 0;
    cvt.rn.f32.s32 %f2, %r17;
    ld.global.u16 %h1, [%rd19];
    cvt.f32.f16 %f3, %h1;
    ld.global.f32 %f4, [%rd21];
    mul.rn.f32 %f5, %f3, %f4;
    fma.rn.f32 %f1, %f2, %f5, %f1;

SOA_REDUCE:
    mov.b32 %r20, %f1;
    shfl.sync.down.b32 %r21, %r20, 16, 31, 0xffffffff;
    mov.b32 %f6, %r21; add.f32 %f1, %f1, %f6; mov.b32 %r20, %f1;
    shfl.sync.down.b32 %r21, %r20, 8, 31, 0xffffffff;
    mov.b32 %f6, %r21; add.f32 %f1, %f1, %f6; mov.b32 %r20, %f1;
    shfl.sync.down.b32 %r21, %r20, 4, 31, 0xffffffff;
    mov.b32 %f6, %r21; add.f32 %f1, %f1, %f6; mov.b32 %r20, %f1;
    shfl.sync.down.b32 %r21, %r20, 2, 31, 0xffffffff;
    mov.b32 %f6, %r21; add.f32 %f1, %f1, %f6; mov.b32 %r20, %f1;
    shfl.sync.down.b32 %r21, %r20, 1, 31, 0xffffffff;
    mov.b32 %f6, %r21; add.f32 %f1, %f1, %f6;

    setp.ne.u32 %p4, %r5, 0;            // only lane 0 writes
    @%p4 bra SOA_DONE;
    mul.wide.u32 %rd30, %r9, 4;
    add.s64 %rd31, %rd5, %rd30;
    cvta.to.global.u64 %rd31, %rd31;
    st.global.f32 [%rd31], %f1;

SOA_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_gemm_q8_0_soa: batched GEMM Y[ntok, out] = X[ntok, in] @ W[out, in]^T,
// Q8_0 SoA weights + int8 activations. For PREFILL: the weight row is streamed
// ONCE and reused across a tile of T=4 tokens (4x fewer weight streams than
// looping the GEMV per token). One warp per output row; each warp walks all
// token tiles. Requires in_dim % 128 == 0 (n_blocks % 4 == 0 - holds for every
// real model dim) so there is no block tail. Tokens are padded to a multiple
// of 4 by the caller (extra rows read safely, their outputs are not written).
//   p_wqs [out,in] int8, p_wsc [out,nb] f16, p_xqs [ntok_pad,in] int8,
//   p_xsc [ntok_pad,nb] f32, p_y [ntok,out] f32.
// Launch: grid ceil(out/(ntid/32)) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_gemm_q8_0_soa(
    .param .u64 p_wqs,
    .param .u64 p_wsc,
    .param .u64 p_xqs,
    .param .u64 p_xsc,
    .param .u64 p_y,
    .param .u32 p_out,
    .param .u32 p_in,
    .param .u32 p_ntok
)
{
    .reg .pred %p<8>;
    .reg .b16 %h<3>;
    .reg .b32 %r<48>;
    .reg .f32 %f<40>;
    .reg .b64 %rd<48>;

    ld.param.u64 %rd1, [p_wqs];
    ld.param.u64 %rd2, [p_wsc];
    ld.param.u64 %rd3, [p_xqs];
    ld.param.u64 %rd4, [p_xsc];
    ld.param.u64 %rd5, [p_y];
    ld.param.u32 %r1, [p_out];
    ld.param.u32 %r2, [p_in];
    ld.param.u32 %r40, [p_ntok];

    mov.u32 %r3, %tid.x;
    shr.u32 %r4, %r3, 5;
    and.b32 %r5, %r3, 31;                // lane
    mov.u32 %r6, %ntid.x;
    shr.u32 %r7, %r6, 5;
    mov.u32 %r8, %ctaid.x;
    mad.lo.s32 %r9, %r8, %r7, %r4;       // output row
    setp.ge.u32 %p1, %r9, %r1;
    @%p1 bra GEMM_DONE;

    cvta.to.global.u64 %rd6, %rd1;
    cvta.to.global.u64 %rd7, %rd2;
    cvta.to.global.u64 %rd8, %rd3;
    cvta.to.global.u64 %rd9, %rd4;
    cvta.to.global.u64 %rd5, %rd5;

    shr.u32 %r10, %r2, 5;                // n_blocks
    shr.u32 %r11, %r10, 2;              // n_groups (in % 128 == 0)

    mul.wide.u32 %rd10, %r9, %r2;        // wqs row base
    add.s64 %rd10, %rd6, %rd10;
    mul.wide.u32 %rd11, %r9, %r10;       // wsc row base
    shl.b64 %rd11, %rd11, 1;
    add.s64 %rd11, %rd7, %rd11;
    shl.b32 %r12, %r5, 2;                // lane * 4
    cvt.u64.u32 %rd12, %r12;
    shr.u32 %r13, %r5, 3;                // lane / 8 (block in group)
    cvt.u64.u32 %rd13, %r13;
    shl.b64 %rd14, %rd13, 1;             // (lane/8) * 2  (wsc)
    shl.b64 %rd15, %rd13, 2;             // (lane/8) * 4  (xsc)

    mov.u32 %r14, 0;                     // t0 (token tile base)

GEMM_TILE:
    setp.ge.u32 %p2, %r14, %r40;
    @%p2 bra GEMM_DONE;

    add.s64 %rd20, %rd10, %rd12;         // wqs lane ptr (reset per tile)
    add.s64 %rd21, %rd11, %rd14;         // wsc lane ptr

    add.s32 %r15, %r14, 0;               // slot 0 x ptrs
    mul.wide.u32 %rd22, %r15, %r2;
    add.s64 %rd22, %rd8, %rd22;
    add.s64 %rd22, %rd22, %rd12;
    mul.wide.u32 %rd23, %r15, %r10;
    shl.b64 %rd23, %rd23, 2;
    add.s64 %rd23, %rd9, %rd23;
    add.s64 %rd23, %rd23, %rd15;
    add.s32 %r15, %r14, 1;               // slot 1
    mul.wide.u32 %rd24, %r15, %r2;
    add.s64 %rd24, %rd8, %rd24;
    add.s64 %rd24, %rd24, %rd12;
    mul.wide.u32 %rd25, %r15, %r10;
    shl.b64 %rd25, %rd25, 2;
    add.s64 %rd25, %rd9, %rd25;
    add.s64 %rd25, %rd25, %rd15;
    add.s32 %r15, %r14, 2;               // slot 2
    mul.wide.u32 %rd26, %r15, %r2;
    add.s64 %rd26, %rd8, %rd26;
    add.s64 %rd26, %rd26, %rd12;
    mul.wide.u32 %rd27, %r15, %r10;
    shl.b64 %rd27, %rd27, 2;
    add.s64 %rd27, %rd9, %rd27;
    add.s64 %rd27, %rd27, %rd15;
    add.s32 %r15, %r14, 3;               // slot 3
    mul.wide.u32 %rd28, %r15, %r2;
    add.s64 %rd28, %rd8, %rd28;
    add.s64 %rd28, %rd28, %rd12;
    mul.wide.u32 %rd29, %r15, %r10;
    shl.b64 %rd29, %rd29, 2;
    add.s64 %rd29, %rd9, %rd29;
    add.s64 %rd29, %rd29, %rd15;

    mov.f32 %f10, 0f00000000;
    mov.f32 %f11, 0f00000000;
    mov.f32 %f12, 0f00000000;
    mov.f32 %f13, 0f00000000;
    mov.u32 %r16, 0;

GEMM_WLOOP:
    setp.ge.u32 %p3, %r16, %r11;
    @%p3 bra GEMM_WRITE;

    ld.global.u32 %r17, [%rd20];         // weight qs (once, reused x4)
    ld.global.u16 %h1, [%rd21];          // weight scale (once)
    cvt.f32.f16 %f3, %h1;

    ld.global.u32 %r18, [%rd22];
    dp4a.s32.s32 %r19, %r17, %r18, 0;
    cvt.rn.f32.s32 %f2, %r19;
    ld.global.f32 %f4, [%rd23];
    mul.rn.f32 %f5, %f3, %f4;
    fma.rn.f32 %f10, %f2, %f5, %f10;

    ld.global.u32 %r18, [%rd24];
    dp4a.s32.s32 %r19, %r17, %r18, 0;
    cvt.rn.f32.s32 %f2, %r19;
    ld.global.f32 %f4, [%rd25];
    mul.rn.f32 %f5, %f3, %f4;
    fma.rn.f32 %f11, %f2, %f5, %f11;

    ld.global.u32 %r18, [%rd26];
    dp4a.s32.s32 %r19, %r17, %r18, 0;
    cvt.rn.f32.s32 %f2, %r19;
    ld.global.f32 %f4, [%rd27];
    mul.rn.f32 %f5, %f3, %f4;
    fma.rn.f32 %f12, %f2, %f5, %f12;

    ld.global.u32 %r18, [%rd28];
    dp4a.s32.s32 %r19, %r17, %r18, 0;
    cvt.rn.f32.s32 %f2, %r19;
    ld.global.f32 %f4, [%rd29];
    mul.rn.f32 %f5, %f3, %f4;
    fma.rn.f32 %f13, %f2, %f5, %f13;

    add.s64 %rd20, %rd20, 128;
    add.s64 %rd21, %rd21, 8;
    add.s64 %rd22, %rd22, 128;
    add.s64 %rd23, %rd23, 16;
    add.s64 %rd24, %rd24, 128;
    add.s64 %rd25, %rd25, 16;
    add.s64 %rd26, %rd26, 128;
    add.s64 %rd27, %rd27, 16;
    add.s64 %rd28, %rd28, 128;
    add.s64 %rd29, %rd29, 16;
    add.s32 %r16, %r16, 1;
    bra GEMM_WLOOP;

GEMM_WRITE:
    mov.b32 %r20, %f10;
    shfl.sync.down.b32 %r21, %r20, 16, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f10, %f10, %f6; mov.b32 %r20, %f10;
    shfl.sync.down.b32 %r21, %r20, 8, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f10, %f10, %f6; mov.b32 %r20, %f10;
    shfl.sync.down.b32 %r21, %r20, 4, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f10, %f10, %f6; mov.b32 %r20, %f10;
    shfl.sync.down.b32 %r21, %r20, 2, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f10, %f10, %f6; mov.b32 %r20, %f10;
    shfl.sync.down.b32 %r21, %r20, 1, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f10, %f10, %f6;

    mov.b32 %r20, %f11;
    shfl.sync.down.b32 %r21, %r20, 16, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f11, %f11, %f6; mov.b32 %r20, %f11;
    shfl.sync.down.b32 %r21, %r20, 8, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f11, %f11, %f6; mov.b32 %r20, %f11;
    shfl.sync.down.b32 %r21, %r20, 4, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f11, %f11, %f6; mov.b32 %r20, %f11;
    shfl.sync.down.b32 %r21, %r20, 2, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f11, %f11, %f6; mov.b32 %r20, %f11;
    shfl.sync.down.b32 %r21, %r20, 1, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f11, %f11, %f6;

    mov.b32 %r20, %f12;
    shfl.sync.down.b32 %r21, %r20, 16, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f12, %f12, %f6; mov.b32 %r20, %f12;
    shfl.sync.down.b32 %r21, %r20, 8, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f12, %f12, %f6; mov.b32 %r20, %f12;
    shfl.sync.down.b32 %r21, %r20, 4, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f12, %f12, %f6; mov.b32 %r20, %f12;
    shfl.sync.down.b32 %r21, %r20, 2, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f12, %f12, %f6; mov.b32 %r20, %f12;
    shfl.sync.down.b32 %r21, %r20, 1, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f12, %f12, %f6;

    mov.b32 %r20, %f13;
    shfl.sync.down.b32 %r21, %r20, 16, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f13, %f13, %f6; mov.b32 %r20, %f13;
    shfl.sync.down.b32 %r21, %r20, 8, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f13, %f13, %f6; mov.b32 %r20, %f13;
    shfl.sync.down.b32 %r21, %r20, 4, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f13, %f13, %f6; mov.b32 %r20, %f13;
    shfl.sync.down.b32 %r21, %r20, 2, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f13, %f13, %f6; mov.b32 %r20, %f13;
    shfl.sync.down.b32 %r21, %r20, 1, 31, 0xffffffff; mov.b32 %f6, %r21; add.f32 %f13, %f13, %f6;

    setp.ne.u32 %p4, %r5, 0;             // only lane 0 writes
    @%p4 bra GEMM_ADV;

    add.s32 %r22, %r14, 0;               // slot 0: always in range
    mad.lo.s32 %r23, %r22, %r1, %r9;
    mul.wide.u32 %rd30, %r23, 4;
    add.s64 %rd30, %rd5, %rd30;
    st.global.f32 [%rd30], %f10;

    add.s32 %r22, %r14, 1;
    setp.ge.u32 %p5, %r22, %r40;
    @%p5 bra GEMM_ADV;
    mad.lo.s32 %r23, %r22, %r1, %r9;
    mul.wide.u32 %rd30, %r23, 4;
    add.s64 %rd30, %rd5, %rd30;
    st.global.f32 [%rd30], %f11;

    add.s32 %r22, %r14, 2;
    setp.ge.u32 %p6, %r22, %r40;
    @%p6 bra GEMM_ADV;
    mad.lo.s32 %r23, %r22, %r1, %r9;
    mul.wide.u32 %rd30, %r23, 4;
    add.s64 %rd30, %rd5, %rd30;
    st.global.f32 [%rd30], %f12;

    add.s32 %r22, %r14, 3;
    setp.ge.u32 %p7, %r22, %r40;
    @%p7 bra GEMM_ADV;
    mad.lo.s32 %r23, %r22, %r1, %r9;
    mul.wide.u32 %rd30, %r23, 4;
    add.s64 %rd30, %rd5, %rd30;
    st.global.f32 [%rd30], %f13;

GEMM_ADV:
    add.s32 %r14, %r14, 4;
    bra GEMM_TILE;

GEMM_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_gemv_t_f32: y[c] = sum_r x[r] * A[r*cols + c]  (A column access).
// The attention weighted-V sum: A = V cache [rows, cols], x = softmaxed
// scores, y = head output. One thread per column, sequential over rows -
// same accumulation order as glproc's scalar loop; consecutive threads
// read consecutive addresses (coalesced).
// Launch: grid ceil(cols/256) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_gemv_t_f32(
    .param .u64 p_a,
    .param .u64 p_x,
    .param .u64 p_y,
    .param .u32 p_rows,
    .param .u32 p_cols
)
{
    .reg .pred %p<3>;
    .reg .b32 %r<12>;
    .reg .f32 %f<8>;
    .reg .b64 %rd<16>;

    ld.param.u64 %rd1, [p_a];
    ld.param.u64 %rd2, [p_x];
    ld.param.u64 %rd3, [p_y];
    ld.param.u32 %r1, [p_rows];
    ld.param.u32 %r2, [p_cols];
    mov.u32 %r3, %ctaid.x;
    mov.u32 %r4, %ntid.x;
    mov.u32 %r5, %tid.x;
    mad.lo.s32 %r6, %r3, %r4, %r5;      // c
    setp.ge.u32 %p1, %r6, %r2;
    @%p1 bra GEMVT_DONE;
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    mul.wide.u32 %rd7, %r6, 4;
    add.s64 %rd8, %rd4, %rd7;           // A ptr = A + c*4
    mov.u64 %rd9, %rd5;                 // x ptr
    mul.wide.u32 %rd10, %r2, 4;         // row stride in bytes
    mov.f32 %f1, 0f00000000;
    mov.u32 %r7, 0;                     // r
GEMVT_LOOP:
    setp.ge.u32 %p2, %r7, %r1;
    @%p2 bra GEMVT_STORE;
    ld.global.f32 %f2, [%rd8];
    ld.global.f32 %f3, [%rd9];
    // mul then add (not fma) - matches glproc's `out[d] += w * v_row[d]`
    // rounding exactly, given the identical sequential order over r.
    mul.rn.f32 %f4, %f3, %f2;
    add.f32 %f1, %f1, %f4;
    add.s64 %rd8, %rd8, %rd10;
    add.s64 %rd9, %rd9, 4;
    add.s32 %r7, %r7, 1;
    bra GEMVT_LOOP;
GEMVT_STORE:
    add.s64 %rd11, %rd6, %rd7;
    st.global.f32 [%rd11], %f1;
GEMVT_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_rms_norm_f32: out[i] = x[i] * rsqrt(mean(x^2) + eps) * w[i].
// One block per position (section 16): strided per-thread sum of squares, warp
// shuffle tree, cross-warp partials through shared memory, thread 0
// finishes with IEEE sqrt + reciprocal (rsqrt.approx would burn the
// 1e-6 epsilon), broadcast via shared memory.
// Launch: grid (1) x 256 threads. Shared: 36 B (8 partials + broadcast).
// ---------------------------------------------------------------------------
.visible .entry gl_rms_norm_f32(
    .param .u64 p_x,
    .param .u64 p_w,
    .param .u64 p_out,
    .param .u32 p_dim,
    .param .f32 p_eps
)
{
    .reg .pred %p<8>;
    .reg .b32 %r<20>;
    .reg .f32 %f<20>;
    .reg .b64 %rd<20>;
    .shared .align 4 .b8 sm_rms[36];

    ld.param.u64 %rd1, [p_x];
    ld.param.u64 %rd2, [p_w];
    ld.param.u64 %rd3, [p_out];
    ld.param.u32 %r1, [p_dim];
    ld.param.f32 %f1, [p_eps];
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    mov.u32 %r2, %tid.x;
    mov.u32 %r3, %ntid.x;
    and.b32 %r5, %r2, 31;               // lane
    shr.u32 %r6, %r2, 5;                // warp id
    mov.u32 %r7, sm_rms;                // shared base
    add.s32 %r10, %r3, 31;
    shr.u32 %r11, %r10, 5;              // n_warps

    // strided sum of squares
    mov.f32 %f2, 0f00000000;
    mov.u32 %r4, %r2;
    mul.wide.u32 %rd7, %r2, 4;
    add.s64 %rd8, %rd4, %rd7;           // x ptr
    mul.wide.u32 %rd9, %r3, 4;          // stride bytes
RMS_ACC:
    setp.ge.u32 %p1, %r4, %r1;
    @%p1 bra RMS_WARP_RED;
    ld.global.f32 %f3, [%rd8];
    fma.rn.f32 %f2, %f3, %f3, %f2;
    add.s32 %r4, %r4, %r3;
    add.s64 %rd8, %rd8, %rd9;
    bra RMS_ACC;
RMS_WARP_RED:
    // f32 -> .b32 for shfl, back to f32 for the add (%r16/%r17).
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 16, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 8, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 4, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 2, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 1, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    setp.ne.u32 %p2, %r5, 0;
    @%p2 bra RMS_BARRIER1;
    shl.b32 %r8, %r6, 2;
    add.s32 %r9, %r7, %r8;
    st.shared.f32 [%r9], %f2;
RMS_BARRIER1:
    bar.sync 0;
    setp.ne.u32 %p3, %r2, 0;
    @%p3 bra RMS_BCAST;
    // thread 0: sequential sum of warp partials (deterministic)
    mov.f32 %f5, 0f00000000;
    mov.u32 %r12, 0;
RMS_SUM_WARPS:
    setp.ge.u32 %p4, %r12, %r11;
    @%p4 bra RMS_FINISH;
    shl.b32 %r13, %r12, 2;
    add.s32 %r14, %r7, %r13;
    ld.shared.f32 %f6, [%r14];
    add.f32 %f5, %f5, %f6;
    add.s32 %r12, %r12, 1;
    bra RMS_SUM_WARPS;
RMS_FINISH:
    cvt.rn.f32.u32 %f7, %r1;
    div.rn.f32 %f8, %f5, %f7;           // mean of squares
    add.f32 %f9, %f8, %f1;              // + eps
    sqrt.rn.f32 %f10, %f9;              // IEEE sqrt
    rcp.rn.f32 %f11, %f10;              // IEEE reciprocal
    st.shared.f32 [%r7+32], %f11;
RMS_BCAST:
    bar.sync 0;
    ld.shared.f32 %f12, [%r7+32];       // inv, uniform
    // out[i] = x[i] * inv * w[i]  (same op order as glproc)
    mov.u32 %r15, %r2;
    mul.wide.u32 %rd10, %r2, 4;
    add.s64 %rd11, %rd4, %rd10;
    add.s64 %rd12, %rd5, %rd10;
    add.s64 %rd13, %rd6, %rd10;
RMS_OUT:
    setp.ge.u32 %p5, %r15, %r1;
    @%p5 bra RMS_DONE;
    ld.global.f32 %f13, [%rd11];
    ld.global.f32 %f14, [%rd12];
    mul.rn.f32 %f15, %f13, %f12;
    mul.rn.f32 %f16, %f15, %f14;
    st.global.f32 [%rd13], %f16;
    add.s32 %r15, %r15, %r3;
    add.s64 %rd11, %rd11, %rd9;
    add.s64 %rd12, %rd12, %rd9;
    add.s64 %rd13, %rd13, %rd9;
    bra RMS_OUT;
RMS_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_softmax_scale_f32: s[i] = softmax(s * scale)[i], in place.
// Mirrors glproc attention::softmax including the degenerate branches:
// non-finite max -> uniform 1/n fill; sum <= 0 -> exp values left as-is.
// Two-pass (max, then exp+sum+normalize), one block, warp-shuffle
// reductions with cross-warp partials in shared memory.
// Launch: grid (1) x 256 threads. Shared: 36 B.
// ---------------------------------------------------------------------------
.visible .entry gl_softmax_scale_f32(
    .param .u64 p_s,
    .param .u32 p_n,
    .param .f32 p_scale
)
{
    .reg .pred %p<8>;
    .reg .b32 %r<24>;
    .reg .f32 %f<24>;
    .reg .b64 %rd<16>;
    .shared .align 4 .b8 sm_sf[36];

    ld.param.u64 %rd1, [p_s];
    ld.param.u32 %r1, [p_n];
    ld.param.f32 %f1, [p_scale];
    cvta.to.global.u64 %rd2, %rd1;
    mov.u32 %r2, %tid.x;
    mov.u32 %r3, %ntid.x;
    and.b32 %r4, %r2, 31;               // lane
    shr.u32 %r5, %r2, 5;                // warp id
    mov.u32 %r6, sm_sf;                 // shared base
    add.s32 %r11, %r3, 31;
    shr.u32 %r12, %r11, 5;              // n_warps
    mul.wide.u32 %rd3, %r3, 4;          // stride bytes
    mul.wide.u32 %rd4, %r2, 4;
    add.s64 %rd5, %rd2, %rd4;           // this thread's base ptr

    // ---- pass 1: max of s[i] * scale ----
    mov.f32 %f2, 0fFF800000;            // -inf
    mov.u32 %r7, %r2;
    mov.u64 %rd6, %rd5;
SF_MAX_LOOP:
    setp.ge.u32 %p1, %r7, %r1;
    @%p1 bra SF_MAX_RED;
    ld.global.f32 %f3, [%rd6];
    mul.rn.f32 %f3, %f3, %f1;
    max.f32 %f2, %f2, %f3;
    add.s32 %r7, %r7, %r3;
    add.s64 %rd6, %rd6, %rd3;
    bra SF_MAX_LOOP;
SF_MAX_RED:
    // f32 -> .b32 for shfl, back to f32 for the max (%r18/%r19).
    mov.b32 %r18, %f2;
    shfl.sync.down.b32 %r19, %r18, 16, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    max.f32 %f2, %f2, %f4;
    mov.b32 %r18, %f2;
    shfl.sync.down.b32 %r19, %r18, 8, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    max.f32 %f2, %f2, %f4;
    mov.b32 %r18, %f2;
    shfl.sync.down.b32 %r19, %r18, 4, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    max.f32 %f2, %f2, %f4;
    mov.b32 %r18, %f2;
    shfl.sync.down.b32 %r19, %r18, 2, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    max.f32 %f2, %f2, %f4;
    mov.b32 %r18, %f2;
    shfl.sync.down.b32 %r19, %r18, 1, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    max.f32 %f2, %f2, %f4;
    setp.ne.u32 %p2, %r4, 0;
    @%p2 bra SF_MAX_BARRIER;
    shl.b32 %r8, %r5, 2;
    add.s32 %r9, %r6, %r8;
    st.shared.f32 [%r9], %f2;
SF_MAX_BARRIER:
    bar.sync 0;
    setp.ne.u32 %p3, %r2, 0;
    @%p3 bra SF_MAX_BCAST;
    mov.f32 %f5, 0fFF800000;
    mov.u32 %r10, 0;
SF_MAX_WARPS:
    setp.ge.u32 %p4, %r10, %r12;
    @%p4 bra SF_MAX_STORE;
    shl.b32 %r13, %r10, 2;
    add.s32 %r14, %r6, %r13;
    ld.shared.f32 %f6, [%r14];
    max.f32 %f5, %f5, %f6;
    add.s32 %r10, %r10, 1;
    bra SF_MAX_WARPS;
SF_MAX_STORE:
    st.shared.f32 [%r6+32], %f5;
SF_MAX_BCAST:
    bar.sync 0;
    ld.shared.f32 %f7, [%r6+32];        // m, uniform
    testp.finite.f32 %p5, %f7;
    @%p5 bra SF_EXP;
    // degenerate row (all -inf): uniform 1/n, like glproc
    cvt.rn.f32.u32 %f8, %r1;
    rcp.rn.f32 %f9, %f8;
    mov.u32 %r15, %r2;
    mov.u64 %rd7, %rd5;
SF_FILL:
    setp.ge.u32 %p6, %r15, %r1;
    @%p6 bra SF_END;
    st.global.f32 [%rd7], %f9;
    add.s32 %r15, %r15, %r3;
    add.s64 %rd7, %rd7, %rd3;
    bra SF_FILL;

    // ---- pass 2: exp(v - m), sum, normalize ----
SF_EXP:
    mov.f32 %f10, 0f00000000;
    mov.u32 %r16, %r2;
    mov.u64 %rd8, %rd5;
SF_EXP_LOOP:
    setp.ge.u32 %p6, %r16, %r1;
    @%p6 bra SF_SUM_RED;
    ld.global.f32 %f11, [%rd8];
    mul.rn.f32 %f11, %f11, %f1;         // v = s[i] * scale
    sub.f32 %f12, %f11, %f7;            // v - m
    mul.f32 %f13, %f12, 0f3FB8AA3B;     // * log2(e)
    ex2.approx.f32 %f14, %f13;          // exp(v - m)
    st.global.f32 [%rd8], %f14;
    add.f32 %f10, %f10, %f14;
    add.s32 %r16, %r16, %r3;
    add.s64 %rd8, %rd8, %rd3;
    bra SF_EXP_LOOP;
SF_SUM_RED:
    // f32 -> .b32 for shfl, back to f32 for the add (%r18/%r19).
    mov.b32 %r18, %f10;
    shfl.sync.down.b32 %r19, %r18, 16, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    add.f32 %f10, %f10, %f4;
    mov.b32 %r18, %f10;
    shfl.sync.down.b32 %r19, %r18, 8, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    add.f32 %f10, %f10, %f4;
    mov.b32 %r18, %f10;
    shfl.sync.down.b32 %r19, %r18, 4, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    add.f32 %f10, %f10, %f4;
    mov.b32 %r18, %f10;
    shfl.sync.down.b32 %r19, %r18, 2, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    add.f32 %f10, %f10, %f4;
    mov.b32 %r18, %f10;
    shfl.sync.down.b32 %r19, %r18, 1, 31, 0xffffffff;
    mov.b32 %f4, %r19;
    add.f32 %f10, %f10, %f4;
    setp.ne.u32 %p2, %r4, 0;
    @%p2 bra SF_SUM_BARRIER;
    shl.b32 %r8, %r5, 2;
    add.s32 %r9, %r6, %r8;
    st.shared.f32 [%r9], %f10;
SF_SUM_BARRIER:
    bar.sync 0;
    setp.ne.u32 %p3, %r2, 0;
    @%p3 bra SF_SUM_BCAST;
    mov.f32 %f15, 0f00000000;
    mov.u32 %r10, 0;
SF_SUM_WARPS:
    setp.ge.u32 %p4, %r10, %r12;
    @%p4 bra SF_SUM_STORE;
    shl.b32 %r13, %r10, 2;
    add.s32 %r14, %r6, %r13;
    ld.shared.f32 %f16, [%r14];
    add.f32 %f15, %f15, %f16;
    add.s32 %r10, %r10, 1;
    bra SF_SUM_WARPS;
SF_SUM_STORE:
    st.shared.f32 [%r6+32], %f15;
SF_SUM_BCAST:
    bar.sync 0;
    ld.shared.f32 %f17, [%r6+32];       // sum, uniform
    setp.gt.f32 %p7, %f17, 0f00000000;
    @!%p7 bra SF_END;                   // sum <= 0: leave exp values
    mov.u32 %r17, %r2;
    mov.u64 %rd9, %rd5;
SF_DIV_LOOP:
    setp.ge.u32 %p6, %r17, %r1;
    @%p6 bra SF_END;
    ld.global.f32 %f18, [%rd9];
    div.rn.f32 %f18, %f18, %f17;        // v /= sum, like glproc
    st.global.f32 [%rd9], %f18;
    add.s32 %r17, %r17, %r3;
    add.s64 %rd9, %rd9, %rd3;
    bra SF_DIV_LOOP;
SF_END:
    ret;
}

// ---------------------------------------------------------------------------
// gl_attn_decode_f32: fused single-query decode attention for ALL heads.
//   grid.x = n_heads (one block per query head), blockDim.x = 128.
//
// Per block (head h):
//   kv_head = h / heads_per_kv
//   k_base  = p_k + kv_head * head_stride   (this head's [seq][dim] K region)
//   v_base  = p_v + kv_head * head_stride
//   q       = p_q + h * head_dim            (this head's query vector)
//   out     = p_out + h * head_dim
// Pass 1: threads stride over t in [0,cached_len): scores[t] = (q . k[t]) * scale
//         held in shared memory (sm_sc). Dot is sequential over head_dim, one
//         thread per t -> same accumulation order as glproc dot_f32.
// Pass 2: block softmax over sm_sc[0..cached_len] (max, exp, sum, normalize),
//         same numerically-stable two-pass form and degenerate handling as
//         gl_softmax_scale_f32.
// Pass 3: threads stride over d in [0,head_dim): out[d] = sum_t sm_sc[t]*v[t][d]
//         sequential over t -> matches glproc's `out[d] += w * v_row[d]`.
// Shared: sm_sc[4096 f32] scores + sm_red[36] reduction/broadcast scratch.
// cached_len is bounded by MAX_KV_CONTEXT (4096); one block's scores fit.
// ---------------------------------------------------------------------------
// p_cached_len is a DEVICE POINTER (u64) to the current cached length, read
// at launch time from device memory, so this kernel's launch arguments never
// change token-to-token (M2.2 graph capture).
.visible .entry gl_attn_decode_f32(
    .param .u64 p_q,
    .param .u64 p_k,
    .param .u64 p_v,
    .param .u64 p_out,
    .param .u32 p_head_dim,
    .param .u64 p_cached_len,
    .param .u32 p_heads_per_kv,
    .param .u32 p_head_stride,
    .param .f32 p_scale
)
{
    .reg .pred %p<8>;
    .reg .b32 %r<40>;
    .reg .f32 %f<32>;
    .reg .b64 %rd<40>;
    .shared .align 4 .b8 sm_sc[16384];   // scores[0..4096]
    .shared .align 4 .b8 sm_red[36];     // warp partials + broadcast

    ld.param.u64 %rd1, [p_q];
    ld.param.u64 %rd2, [p_k];
    ld.param.u64 %rd3, [p_v];
    ld.param.u64 %rd4, [p_out];
    ld.param.u32 %r1, [p_head_dim];
    ld.param.u64 %rd30, [p_cached_len];  // device ptr to cached_len
    cvta.to.global.u64 %rd31, %rd30;
    ld.global.u32 %r2, [%rd31];          // cached_len
    ld.param.u32 %r3, [p_heads_per_kv];
    ld.param.u32 %r4, [p_head_stride];
    ld.param.f32 %f1, [p_scale];

    mov.u32 %r5, %ctaid.x;               // h (query head)
    mov.u32 %r6, %tid.x;                 // thread id
    mov.u32 %r7, %ntid.x;                // block size
    and.b32 %r8, %r6, 31;                // lane
    shr.u32 %r9, %r6, 5;                 // warp id
    add.s32 %r10, %r7, 31;
    shr.u32 %r11, %r10, 5;               // n_warps
    mov.u32 %r12, sm_sc;                 // scores base (shared)
    mov.u32 %r13, sm_red;                // reduction base (shared)

    cvta.to.global.u64 %rd5, %rd1;       // q global
    cvta.to.global.u64 %rd6, %rd2;       // k global
    cvta.to.global.u64 %rd7, %rd3;       // v global
    cvta.to.global.u64 %rd8, %rd4;       // out global

    // kv_head = h / heads_per_kv ; kv offset in elements = kv_head*head_stride
    div.u32 %r14, %r5, %r3;              // kv_head
    mul.lo.s32 %r15, %r14, %r4;          // kv_head * head_stride (elems)
    mul.wide.u32 %rd9, %r15, 4;
    add.s64 %rd10, %rd6, %rd9;           // k_base for this head
    add.s64 %rd11, %rd7, %rd9;           // v_base for this head
    // q vector base = q + h*head_dim
    mul.lo.s32 %r16, %r5, %r1;
    mul.wide.u32 %rd12, %r16, 4;
    add.s64 %rd13, %rd5, %rd12;          // q_base
    add.s64 %rd14, %rd8, %rd12;          // out_base

    // ---- Pass 1: scores[t] = (q . k[t]) * scale, one thread per t ----
    mov.u32 %r17, %r6;                   // t = tid
ATTN_SCORE:
    setp.ge.u32 %p1, %r17, %r2;
    @%p1 bra ATTN_SCORE_DONE;
    // k row t base = k_base + t*head_dim
    mul.lo.s32 %r18, %r17, %r1;
    mul.wide.u32 %rd15, %r18, 4;
    add.s64 %rd16, %rd10, %rd15;         // &k[t][0]
    mov.u64 %rd17, %rd13;                // &q[0]
    mov.f32 %f2, 0f00000000;             // dot acc (FP32)
    mov.u32 %r19, 0;                     // d
ATTN_DOT:
    setp.ge.u32 %p2, %r19, %r1;
    @%p2 bra ATTN_DOT_DONE;
    ld.global.f32 %f3, [%rd17];
    ld.global.f32 %f4, [%rd16];
    fma.rn.f32 %f2, %f3, %f4, %f2;
    add.s64 %rd17, %rd17, 4;
    add.s64 %rd16, %rd16, 4;
    add.s32 %r19, %r19, 1;
    bra ATTN_DOT;
ATTN_DOT_DONE:
    mul.rn.f32 %f2, %f2, %f1;            // * scale
    // store into shared scores[t]
    shl.b32 %r20, %r17, 2;
    add.s32 %r21, %r12, %r20;
    st.shared.f32 [%r21], %f2;
    add.s32 %r17, %r17, %r7;             // t += blockDim
    bra ATTN_SCORE;
ATTN_SCORE_DONE:
    bar.sync 0;

    // ---- Pass 2: softmax over sm_sc[0..cached_len] ----
    // max reduction (strided per thread over shared scores)
    mov.f32 %f5, 0fFF800000;             // -inf
    mov.u32 %r22, %r6;
ATTN_MAX:
    setp.ge.u32 %p3, %r22, %r2;
    @%p3 bra ATTN_MAX_RED;
    shl.b32 %r23, %r22, 2;
    add.s32 %r24, %r12, %r23;
    ld.shared.f32 %f6, [%r24];
    max.f32 %f5, %f5, %f6;
    add.s32 %r22, %r22, %r7;
    bra ATTN_MAX;
ATTN_MAX_RED:
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 16, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 8, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 4, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 2, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 1, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    setp.ne.u32 %p4, %r8, 0;
    @%p4 bra ATTN_MAX_BAR;
    shl.b32 %r27, %r9, 2;
    add.s32 %r28, %r13, %r27;
    st.shared.f32 [%r28], %f5;
ATTN_MAX_BAR:
    bar.sync 0;
    setp.ne.u32 %p5, %r6, 0;
    @%p5 bra ATTN_MAX_BC;
    mov.f32 %f7, 0fFF800000;
    mov.u32 %r29, 0;
ATTN_MAX_W:
    setp.ge.u32 %p6, %r29, %r11;
    @%p6 bra ATTN_MAX_ST;
    shl.b32 %r30, %r29, 2;
    add.s32 %r31, %r13, %r30;
    ld.shared.f32 %f8, [%r31];
    max.f32 %f7, %f7, %f8;
    add.s32 %r29, %r29, 1;
    bra ATTN_MAX_W;
ATTN_MAX_ST:
    st.shared.f32 [%r13+32], %f7;
ATTN_MAX_BC:
    bar.sync 0;
    ld.shared.f32 %f9, [%r13+32];        // m (block max), uniform

    // exp(score - m) written back to shared, plus per-thread sum
    mov.f32 %f10, 0f00000000;            // sum acc
    mov.u32 %r32, %r6;
ATTN_EXP:
    setp.ge.u32 %p3, %r32, %r2;
    @%p3 bra ATTN_SUM_RED;
    shl.b32 %r33, %r32, 2;
    add.s32 %r34, %r12, %r33;
    ld.shared.f32 %f11, [%r34];
    sub.f32 %f12, %f11, %f9;             // score - m
    mul.f32 %f13, %f12, 0f3FB8AA3B;      // * log2(e)
    ex2.approx.f32 %f14, %f13;           // exp(score - m)
    st.shared.f32 [%r34], %f14;
    add.f32 %f10, %f10, %f14;
    add.s32 %r32, %r32, %r7;
    bra ATTN_EXP;
ATTN_SUM_RED:
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 16, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 8, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 4, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 2, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 1, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    setp.ne.u32 %p4, %r8, 0;
    @%p4 bra ATTN_SUM_BAR;
    shl.b32 %r27, %r9, 2;
    add.s32 %r28, %r13, %r27;
    st.shared.f32 [%r28], %f10;
ATTN_SUM_BAR:
    bar.sync 0;
    setp.ne.u32 %p5, %r6, 0;
    @%p5 bra ATTN_SUM_BC;
    mov.f32 %f15, 0f00000000;
    mov.u32 %r29, 0;
ATTN_SUM_W:
    setp.ge.u32 %p6, %r29, %r11;
    @%p6 bra ATTN_SUM_ST;
    shl.b32 %r30, %r29, 2;
    add.s32 %r31, %r13, %r30;
    ld.shared.f32 %f16, [%r31];
    add.f32 %f15, %f15, %f16;
    add.s32 %r29, %r29, 1;
    bra ATTN_SUM_W;
ATTN_SUM_ST:
    st.shared.f32 [%r13+32], %f15;
ATTN_SUM_BC:
    bar.sync 0;
    ld.shared.f32 %f17, [%r13+32];       // sum, uniform
    // reciprocal of sum (guard sum>0, else leave weights = exp values)
    setp.gt.f32 %p7, %f17, 0f00000000;
    mov.f32 %f18, 0f3F800000;            // 1.0 default (no-op divide)
    @!%p7 bra ATTN_RCP_DONE;
    rcp.rn.f32 %f18, %f17;               // 1/sum
ATTN_RCP_DONE:
    bar.sync 0;

    // ---- Pass 3: out[d] = sum_t (scores[t]*inv_sum) * v[t][d] ----
    // one thread per d, sequential over t (matches glproc weighted-V order).
    mov.u32 %r35, %r6;                   // d = tid
ATTN_OUT:
    setp.ge.u32 %p1, %r35, %r1;
    @%p1 bra ATTN_OUT_DONE;
    mov.f32 %f19, 0f00000000;            // out acc
    mov.u32 %r36, 0;                     // t
    // &v[0][d] = v_base + d*4 ; stride between t rows = head_dim*4 bytes
    mul.wide.u32 %rd18, %r35, 4;
    add.s64 %rd19, %rd11, %rd18;         // &v[0][d]
    mul.lo.s32 %r37, %r1, 4;             // row stride bytes
    cvt.u64.u32 %rd20, %r37;
ATTN_OUT_LOOP:
    setp.ge.u32 %p2, %r36, %r2;
    @%p2 bra ATTN_OUT_STORE;
    shl.b32 %r38, %r36, 2;
    add.s32 %r39, %r12, %r38;
    ld.shared.f32 %f20, [%r39];          // exp weight (un-normalized)
    mul.rn.f32 %f21, %f20, %f18;         // * inv_sum -> normalized weight
    ld.global.f32 %f22, [%rd19];         // v[t][d]
    fma.rn.f32 %f19, %f21, %f22, %f19;
    add.s64 %rd19, %rd19, %rd20;
    add.s32 %r36, %r36, 1;
    bra ATTN_OUT_LOOP;
ATTN_OUT_STORE:
    // out[d] at out_base + d*4
    add.s64 %rd21, %rd14, %rd18;
    st.global.f32 [%rd21], %f19;
    add.s32 %r35, %r35, %r7;
    bra ATTN_OUT;
ATTN_OUT_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_kv_write: copy this token's K (or V) rows for all KV heads from the
// workspace into the cache at sequence position `pos` (read from device
// memory, so launch args are token-invariant for M2.2 graph capture).
//
//   src is [n_kv_heads * head_dim] contiguous (the workspace k_ptr / v_ptr).
//   dst_base is the cache region for (layer, kv, head 0); head h lives at
//   dst_base + h*head_stride, and this token's row at + pos*head_dim.
//   element e -> kv_head = e / head_dim, d = e % head_dim
//              -> dst_base + kv_head*head_stride + pos*head_dim + d
// Launch: grid ceil(n_kv_heads*head_dim / 256) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_kv_write(
    .param .u64 p_dst,
    .param .u64 p_src,
    .param .u64 p_pos,
    .param .u32 p_head_dim,
    .param .u32 p_n_kv,
    .param .u32 p_head_stride
)
{
    .reg .pred %p<2>;
    .reg .b32 %r<16>;
    .reg .f32 %f<2>;
    .reg .b64 %rd<16>;

    ld.param.u64 %rd1, [p_dst];
    ld.param.u64 %rd2, [p_src];
    ld.param.u64 %rd3, [p_pos];
    ld.param.u32 %r1, [p_head_dim];
    ld.param.u32 %r2, [p_n_kv];
    ld.param.u32 %r3, [p_head_stride];
    mov.u32 %r4, %ctaid.x;
    mov.u32 %r5, %ntid.x;
    mov.u32 %r6, %tid.x;
    mad.lo.s32 %r7, %r4, %r5, %r6;       // e = global element index
    mul.lo.s32 %r8, %r2, %r1;            // n_kv * head_dim
    setp.ge.u32 %p1, %r7, %r8;
    @%p1 bra KVW_DONE;
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    ld.global.u32 %r9, [%rd6];           // pos
    div.u32 %r10, %r7, %r1;              // kv_head = e / head_dim
    rem.u32 %r11, %r7, %r1;              // d = e % head_dim
    mul.lo.s32 %r12, %r10, %r3;          // kv_head * head_stride
    mul.lo.s32 %r13, %r9, %r1;           // pos * head_dim
    add.s32 %r14, %r12, %r13;
    add.s32 %r15, %r14, %r11;            // dst element index
    // load src[e]
    mul.wide.u32 %rd7, %r7, 4;
    add.s64 %rd8, %rd5, %rd7;
    ld.global.f32 %f1, [%rd8];
    // store dst[idx]
    mul.wide.u32 %rd9, %r15, 4;
    add.s64 %rd10, %rd4, %rd9;
    st.global.f32 [%rd10], %f1;
KVW_DONE:
    ret;
}
// ---------------------------------------------------------------------------// ---------------------------------------------------------------------------
// gl_gemv_q4_0: y = W @ x with W in GGML Q4_0 blocks (18 B: f16 scale d +
// 16 bytes of nibbles; weight = d * (q - 8)).
// Launch: grid (out_dim) x 32 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_gemv_q4_0(
    .param .u64 p_w,
    .param .u64 p_x,
    .param .u64 p_y,
    .param .u32 p_out,
    .param .u32 p_in
)
{
    .reg .pred %p<6>;
    .reg .b16 %h<2>;
    .reg .b32 %r<30>;
    .reg .f32 %f<10>;
    .reg .b64 %rd<20>;

    ld.param.u64 %rd1, [p_w];
    ld.param.u64 %rd2, [p_x];
    ld.param.u64 %rd3, [p_y];
    ld.param.u32 %r1, [p_out];
    ld.param.u32 %r2, [p_in];
    
    mov.u32 %r3, %ctaid.x;              // row
    setp.ge.u32 %p1, %r3, %r1;
    @%p1 bra GEMVQ4_DONE;
    
    mov.u32 %r4, %tid.x;                // lane
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    
    shr.u32 %r5, %r2, 5;                // n_blocks = in_dim / 32
    
    mul.lo.s32 %r6, %r5, 18;            // row_bytes = n_blocks * 18
    mul.wide.u32 %rd7, %r3, %r6;
    add.s64 %rd8, %rd4, %rd7;           // row_base = W + row * row_bytes

    // d_ptr = row_base + b*18
    mov.u64 %rd9, %rd8;
    
    // qs_ptr = row_base + b*18 + 2 + (lane % 16)
    and.b32 %r7, %r4, 15;               // lane % 16
    add.s32 %r8, %r7, 2;
    cvt.u64.u32 %rd10, %r8;
    add.s64 %rd11, %rd8, %rd10;         // qs_ptr

    // x_ptr = X + b*128 + lane*4
    mul.wide.u32 %rd12, %r4, 4;
    add.s64 %rd13, %rd5, %rd12;         // x_ptr

    setp.lt.u32 %p2, %r4, 16;           // is_lower_nibble = lane < 16

    mov.f32 %f1, 0f00000000;            // acc = 0.0
    mov.u32 %r9, 0;                     // b = 0

GEMVQ4_LOOP:
    setp.ge.u32 %p3, %r9, %r5;
    @%p3 bra GEMVQ4_REDUCE;
    
    ld.global.b16 %h1, [%rd9];          // load scale d
    cvt.f32.f16 %f2, %h1;
    
    ld.global.u8 %r10, [%rd11];         // load byte
    @%p2 and.b32 %r10, %r10, 0x0F;
    @!%p2 shr.u32 %r10, %r10, 4;
    @!%p2 and.b32 %r10, %r10, 0x0F;
    sub.s32 %r10, %r10, 8;              // q - 8
    cvt.rn.f32.s32 %f3, %r10;
    
    mul.rn.f32 %f4, %f2, %f3;           // weight = d * (q - 8)
    
    ld.global.f32 %f5, [%rd13];         // load x
    fma.rn.f32 %f1, %f4, %f5, %f1;      // acc += weight * x
    
    add.s64 %rd9, %rd9, 18;             // d_ptr += 18
    add.s64 %rd11, %rd11, 18;           // qs_ptr += 18
    add.s64 %rd13, %rd13, 128;          // x_ptr += 128 (32 floats)
    add.s32 %r9, %r9, 1;
    bra GEMVQ4_LOOP;

GEMVQ4_REDUCE:
    mov.b32 %r11, %f1;
    shfl.sync.down.b32 %r12, %r11, 16, 31, 0xffffffff;
    mov.b32 %f6, %r12; add.f32 %f1, %f1, %f6; mov.b32 %r11, %f1;
    shfl.sync.down.b32 %r12, %r11, 8, 31, 0xffffffff;
    mov.b32 %f6, %r12; add.f32 %f1, %f1, %f6; mov.b32 %r11, %f1;
    shfl.sync.down.b32 %r12, %r11, 4, 31, 0xffffffff;
    mov.b32 %f6, %r12; add.f32 %f1, %f1, %f6; mov.b32 %r11, %f1;
    shfl.sync.down.b32 %r12, %r11, 2, 31, 0xffffffff;
    mov.b32 %f6, %r12; add.f32 %f1, %f1, %f6; mov.b32 %r11, %f1;
    shfl.sync.down.b32 %r12, %r11, 1, 31, 0xffffffff;
    mov.b32 %f6, %r12; add.f32 %f1, %f1, %f6;
    
    setp.ne.u32 %p4, %r4, 0;
    @%p4 bra GEMVQ4_DONE;
    
    mul.wide.u32 %rd14, %r3, 4;
    add.s64 %rd15, %rd6, %rd14;
    st.global.f32 [%rd15], %f1;

GEMVQ4_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_gemv_q4_k_soa: y = W @ x, Q4_K weights in STRUCTURE-OF-ARRAYS layout
// (M2.1 Task A - the decode-bandwidth kernel: 5.0 bpw streamed vs 8.5 for
// Q8_0 SoA).
//
//   p_wqs : contiguous 4-bit quants [out_dim * in_dim / 2] (u8). Packed at
//           repack time so one u32 holds 8 CONSECUTIVE values:
//             byte j = v[8g+j] | v[8g+4+j] << 4     (j = 0..4, group g)
//           so   w & 0x0F0F0F0F  = values 8g..8g+4   (one int8 x4 lane set)
//                (w>>4) & 0x0F.. = values 8g+4..8g+8 (the next one)
//           and each half lines up with one aligned u32 of int8 activations.
//   p_wsc : f16 PRE-MULTIPLIED sub-block scales d*sc [out_dim * in_dim/32].
//           Pre-multiplying at repack removes ggml's 6-bit scale unpack
//           (branchy, j<4 / j>=4 asymmetric) from the hot loop.
//   p_wmn : f16 pre-multiplied sub-block mins dmin*m, same shape.
//   p_xqs : int8 quantized activation [in_dim] (gl_quantize_q8 output).
//   p_xsc : f32 activation block scales [in_dim/32].
//   p_y   : f32 output [out_dim].
//
// Math per 32-weight sub-block (matches the activation quantizer's block):
//   w_i = (d*sc)*q_i - (dmin*m),  x_i = xs*xq_i
//   sum w_i*x_i = (d*sc)*xs * dot(q, xq) - (dmin*m)*xs * sum(xq)
// Both integer terms come from dp4a chains (q nibbles are 0..15, safely
// inside the positive s8 range; sum(xq) is dp4a against 0x01010101).
//
// One warp per output row, one ITERATION per 256-weight super-block: the 32
// lanes read 128 contiguous qs bytes (one coalesced transaction) and 256
// activation bytes; lane l owns values 8l..8l+8, i.e. sub-block l/4, whose
// scale/min/xscale it reads directly. FP32 accumulation, 32-lane shuffle
// reduction, lane 0 writes.
//
// in_dim must be a multiple of 256 (guaranteed: ggml cannot produce a Q4_K
// tensor whose row length is not - QK_K divisibility is a format invariant).
// Launch: grid ceil(out_dim / (ntid/32)) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_gemv_q4_k_soa(
    .param .u64 p_wqs,
    .param .u64 p_wsc,
    .param .u64 p_wmn,
    .param .u64 p_xqs,
    .param .u64 p_xsc,
    .param .u64 p_y,
    .param .u32 p_out,
    .param .u32 p_in
)
{
    .reg .pred %p<5>;
    .reg .b16 %h<4>;
    .reg .b32 %r<32>;
    .reg .f32 %f<14>;
    .reg .b64 %rd<40>;

    ld.param.u64 %rd1, [p_wqs];
    ld.param.u64 %rd2, [p_wsc];
    ld.param.u64 %rd3, [p_wmn];
    ld.param.u64 %rd4, [p_xqs];
    ld.param.u64 %rd5, [p_xsc];
    ld.param.u64 %rd6, [p_y];
    ld.param.u32 %r1, [p_out];
    ld.param.u32 %r2, [p_in];

    mov.u32 %r3, %tid.x;
    shr.u32 %r4, %r3, 5;                 // warp_id
    and.b32 %r5, %r3, 31;                // lane
    mov.u32 %r6, %ntid.x;
    shr.u32 %r7, %r6, 5;                 // warps per block
    mov.u32 %r8, %ctaid.x;
    mad.lo.s32 %r9, %r8, %r7, %r4;       // output row
    setp.ge.u32 %p1, %r9, %r1;
    @%p1 bra Q4K_DONE;

    cvta.to.global.u64 %rd7, %rd1;
    cvta.to.global.u64 %rd8, %rd2;
    cvta.to.global.u64 %rd9, %rd3;
    cvta.to.global.u64 %rd10, %rd4;
    cvta.to.global.u64 %rd11, %rd5;

    shr.u32 %r10, %r2, 8;                // n_sb = in_dim / 256 super-blocks
    shr.u32 %r11, %r2, 1;                // qs row bytes = in_dim / 2

    // Row bases.
    mul.wide.u32 %rd12, %r9, %r11;       // row * in/2
    add.s64 %rd13, %rd7, %rd12;          // wqs row base
    mul.wide.u32 %rd14, %r9, %r10;       // row * n_sb
    shl.b64 %rd14, %rd14, 4;             // * 16 B (8 f16 scales / super-block)
    add.s64 %rd15, %rd8, %rd14;          // wsc row base
    add.s64 %rd16, %rd9, %rd14;          // wmn row base

    // Lane offsets. Lane l: qs u32 at l*4; activations at l*8; its
    // sub-block index within the super-block is l/4.
    shl.b32 %r12, %r5, 2;                // lane * 4
    cvt.u64.u32 %rd17, %r12;
    add.s64 %rd18, %rd13, %rd17;         // wqs lane ptr
    shl.b32 %r13, %r5, 3;                // lane * 8
    cvt.u64.u32 %rd19, %r13;
    add.s64 %rd20, %rd10, %rd19;         // xqs lane ptr
    shr.u32 %r14, %r5, 2;                // sub-block = lane / 4 (0..7)
    cvt.u64.u32 %rd21, %r14;
    shl.b64 %rd22, %rd21, 1;
    add.s64 %rd23, %rd15, %rd22;         // wsc lane ptr (f16)
    add.s64 %rd24, %rd16, %rd22;         // wmn lane ptr (f16)
    shl.b64 %rd25, %rd21, 2;
    add.s64 %rd26, %rd11, %rd25;         // xsc lane ptr (f32)

    mov.f32 %f1, 0f00000000;             // FP32 accumulator
    mov.u32 %r15, 0x01010101;            // dp4a "ones" for sum(xq)
    mov.u32 %r16, 0;                     // super-block index

Q4K_LOOP:
    setp.ge.u32 %p2, %r16, %r10;
    @%p2 bra Q4K_REDUCE;

    ld.global.u32 %r17, [%rd18];         // 8 packed weight nibbles
    and.b32 %r18, %r17, 0x0F0F0F0F;      // values 8g..8g+4
    shr.u32 %r19, %r17, 4;
    and.b32 %r19, %r19, 0x0F0F0F0F;      // values 8g+4..8g+8
    ld.global.u32 %r20, [%rd20];         // xq bytes 0..3
    ld.global.u32 %r21, [%rd20+4];       // xq bytes 4..7
    dp4a.s32.s32 %r22, %r18, %r20, 0;
    dp4a.s32.s32 %r22, %r19, %r21, %r22; // idot = dot(q, xq)
    dp4a.s32.s32 %r23, %r20, %r15, 0;
    dp4a.s32.s32 %r23, %r21, %r15, %r23; // isum = sum(xq)

    ld.global.u16 %h1, [%rd23];
    cvt.f32.f16 %f2, %h1;                // sc = f16(d * sc_j)
    ld.global.u16 %h2, [%rd24];
    cvt.f32.f16 %f3, %h2;                // mn = f16(dmin * m_j)
    ld.global.f32 %f4, [%rd26];          // xs (activation block scale)

    cvt.rn.f32.s32 %f5, %r22;
    cvt.rn.f32.s32 %f6, %r23;
    mul.rn.f32 %f7, %f2, %f4;            // sc * xs
    fma.rn.f32 %f1, %f5, %f7, %f1;       // acc += idot * sc*xs
    mul.rn.f32 %f8, %f3, %f4;            // mn * xs
    neg.f32 %f8, %f8;
    fma.rn.f32 %f1, %f6, %f8, %f1;       // acc -= isum * mn*xs

    add.s64 %rd18, %rd18, 128;           // qs: 128 B / super-block
    add.s64 %rd20, %rd20, 256;           // xq: 256 B
    add.s64 %rd23, %rd23, 16;            // scales: 8 f16
    add.s64 %rd24, %rd24, 16;            // mins: 8 f16
    add.s64 %rd26, %rd26, 32;            // xsc: 8 f32
    add.s32 %r16, %r16, 1;
    bra Q4K_LOOP;

Q4K_REDUCE:
    mov.b32 %r24, %f1;
    shfl.sync.down.b32 %r25, %r24, 16, 31, 0xffffffff;
    mov.b32 %f9, %r25; add.f32 %f1, %f1, %f9; mov.b32 %r24, %f1;
    shfl.sync.down.b32 %r25, %r24, 8, 31, 0xffffffff;
    mov.b32 %f9, %r25; add.f32 %f1, %f1, %f9; mov.b32 %r24, %f1;
    shfl.sync.down.b32 %r25, %r24, 4, 31, 0xffffffff;
    mov.b32 %f9, %r25; add.f32 %f1, %f1, %f9; mov.b32 %r24, %f1;
    shfl.sync.down.b32 %r25, %r24, 2, 31, 0xffffffff;
    mov.b32 %f9, %r25; add.f32 %f1, %f1, %f9; mov.b32 %r24, %f1;
    shfl.sync.down.b32 %r25, %r24, 1, 31, 0xffffffff;
    mov.b32 %f9, %r25; add.f32 %f1, %f1, %f9;

    setp.ne.u32 %p3, %r5, 0;             // only lane 0 writes
    @%p3 bra Q4K_DONE;
    mul.wide.u32 %rd27, %r9, 4;
    add.s64 %rd28, %rd6, %rd27;
    cvta.to.global.u64 %rd28, %rd28;
    st.global.f32 [%rd28], %f1;

Q4K_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_gemv_q4_0_soa: y = W @ x, Q4_0 weights in STRUCTURE-OF-ARRAYS layout
// (M2.2 Task C-2 - the speed-first 4.5 bpw decode kernel; the AoS
// gl_gemv_q4_0 above is legacy and not used by the matmul dispatch).
//
//   p_wqs : contiguous 4-bit quants [out_dim * in_dim / 2] (u8), packed at
//           repack time in the same order as Q4_K SoA: one u32 holds 8
//           CONSECUTIVE values (byte j = v[8g+j] | v[8g+4+j] << 4), so
//           w & 0x0F0F0F0F and (w>>4) & 0x0F0F0F0F are two int8x4 operands
//           each matching one aligned u32 of int8 activations.
//   p_wsc : VERBATIM f16 block scales d [out_dim * in_dim/32] - no
//           pre-multiply (d is already the final scale), no rounding loss.
//   p_xqs / p_xsc : int8 activation + f32 block scales (gl_quantize_q8).
//   p_y   : f32 output [out_dim].
//
// Math per 32-weight block:  w_i = d*(q_i - 8),  x_i = xs*xq_i
//   sum w_i*x_i = d*xs * (dot(q, xq) - 8*sum(xq))
// The -8 centering folds into the INTEGER domain (idot - 8*isum, exact),
// so each block costs one f32 multiply + one fma - simpler than Q4_K
// (no mins stream, no second fma).
//
// One warp per output row; one iteration covers 256 values = 8 blocks
// (lane l owns values 8l..8l+8, i.e. block l/4, whose f16 scale and f32
// activation scale it reads directly). A guarded tail iteration handles
// in_dim % 256 != 0 (Q4_0 only requires 32-value blocks - dim-896 models
// are legal, unlike Q4_K/Q6_K): the last (in/32)%8 blocks are processed by
// the lanes whose block index falls inside the remainder.
// Launch: grid ceil(out_dim / (ntid/32)) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_gemv_q4_0_soa(
    .param .u64 p_wqs,
    .param .u64 p_wsc,
    .param .u64 p_xqs,
    .param .u64 p_xsc,
    .param .u64 p_y,
    .param .u32 p_out,
    .param .u32 p_in
)
{
    .reg .pred %p<6>;
    .reg .b16 %h<3>;
    .reg .b32 %r<32>;
    .reg .f32 %f<12>;
    .reg .b64 %rd<36>;

    ld.param.u64 %rd1, [p_wqs];
    ld.param.u64 %rd2, [p_wsc];
    ld.param.u64 %rd3, [p_xqs];
    ld.param.u64 %rd4, [p_xsc];
    ld.param.u64 %rd5, [p_y];
    ld.param.u32 %r1, [p_out];
    ld.param.u32 %r2, [p_in];

    mov.u32 %r3, %tid.x;
    shr.u32 %r4, %r3, 5;                 // warp_id
    and.b32 %r5, %r3, 31;                // lane
    mov.u32 %r6, %ntid.x;
    shr.u32 %r7, %r6, 5;                 // warps per block
    mov.u32 %r8, %ctaid.x;
    mad.lo.s32 %r9, %r8, %r7, %r4;       // output row
    setp.ge.u32 %p1, %r9, %r1;
    @%p1 bra Q40S_DONE;

    cvta.to.global.u64 %rd6, %rd1;
    cvta.to.global.u64 %rd7, %rd2;
    cvta.to.global.u64 %rd8, %rd3;
    cvta.to.global.u64 %rd9, %rd4;

    shr.u32 %r10, %r2, 8;                // n_groups = in / 256 (8 blocks each)
    shr.u32 %r11, %r2, 5;                // n_blocks = in / 32
    and.b32 %r12, %r11, 7;               // tail blocks = n_blocks % 8
    shr.u32 %r13, %r2, 1;                // qs row bytes = in / 2

    // Row bases.
    mul.wide.u32 %rd10, %r9, %r13;
    add.s64 %rd11, %rd6, %rd10;          // wqs row base
    mul.wide.u32 %rd12, %r9, %r11;
    shl.b64 %rd12, %rd12, 1;             // f16 per block
    add.s64 %rd13, %rd7, %rd12;          // wsc row base

    // Lane offsets: lane l owns values 8l..8l+8 = block l/4.
    shl.b32 %r14, %r5, 2;                // lane * 4
    cvt.u64.u32 %rd14, %r14;
    add.s64 %rd15, %rd11, %rd14;         // wqs lane ptr
    shl.b32 %r15, %r5, 3;                // lane * 8
    cvt.u64.u32 %rd16, %r15;
    add.s64 %rd17, %rd8, %rd16;          // xqs lane ptr
    shr.u32 %r16, %r5, 2;                // block-in-group = lane / 4 (0..7)
    cvt.u64.u32 %rd18, %r16;
    shl.b64 %rd19, %rd18, 1;
    add.s64 %rd20, %rd13, %rd19;         // wsc lane ptr (f16)
    shl.b64 %rd21, %rd18, 2;
    add.s64 %rd22, %rd9, %rd21;          // xsc lane ptr (f32)

    mov.f32 %f1, 0f00000000;             // FP32 accumulator
    mov.u32 %r17, 0x01010101;            // dp4a "ones" for sum(xq)
    mov.u32 %r18, 0;                     // group index

Q40S_LOOP:
    setp.ge.u32 %p2, %r18, %r10;
    @%p2 bra Q40S_TAIL;

    ld.global.u32 %r19, [%rd15];         // 8 packed weight nibbles
    and.b32 %r20, %r19, 0x0F0F0F0F;      // values 8g..8g+4
    shr.u32 %r21, %r19, 4;
    and.b32 %r21, %r21, 0x0F0F0F0F;      // values 8g+4..8g+8
    ld.global.u32 %r22, [%rd17];         // xq bytes 0..3
    ld.global.u32 %r23, [%rd17+4];       // xq bytes 4..7
    dp4a.s32.s32 %r24, %r20, %r22, 0;
    dp4a.s32.s32 %r24, %r21, %r23, %r24; // idot = dot(q, xq)
    dp4a.s32.s32 %r25, %r22, %r17, 0;
    dp4a.s32.s32 %r25, %r23, %r17, %r25; // isum = sum(xq)
    shl.b32 %r26, %r25, 3;               // 8 * isum
    sub.s32 %r27, %r24, %r26;            // idot - 8*isum (exact, integer)

    ld.global.u16 %h1, [%rd20];
    cvt.f32.f16 %f2, %h1;                // d (verbatim block scale)
    ld.global.f32 %f3, [%rd22];          // xs
    cvt.rn.f32.s32 %f4, %r27;
    mul.rn.f32 %f5, %f2, %f3;            // d * xs
    fma.rn.f32 %f1, %f4, %f5, %f1;

    add.s64 %rd15, %rd15, 128;           // qs: 128 B / 256 values
    add.s64 %rd17, %rd17, 256;           // xq: 256 B
    add.s64 %rd20, %rd20, 16;            // scales: 8 f16
    add.s64 %rd22, %rd22, 32;            // xsc: 8 f32
    add.s32 %r18, %r18, 1;
    bra Q40S_LOOP;

Q40S_TAIL:
    // Remaining n_blocks % 8 blocks: lane participates when its block
    // index within the group falls inside the remainder.
    setp.lt.u32 %p3, %r16, %r12;
    @!%p3 bra Q40S_REDUCE;
    ld.global.u32 %r19, [%rd15];
    and.b32 %r20, %r19, 0x0F0F0F0F;
    shr.u32 %r21, %r19, 4;
    and.b32 %r21, %r21, 0x0F0F0F0F;
    ld.global.u32 %r22, [%rd17];
    ld.global.u32 %r23, [%rd17+4];
    dp4a.s32.s32 %r24, %r20, %r22, 0;
    dp4a.s32.s32 %r24, %r21, %r23, %r24;
    dp4a.s32.s32 %r25, %r22, %r17, 0;
    dp4a.s32.s32 %r25, %r23, %r17, %r25;
    shl.b32 %r26, %r25, 3;
    sub.s32 %r27, %r24, %r26;
    ld.global.u16 %h1, [%rd20];
    cvt.f32.f16 %f2, %h1;
    ld.global.f32 %f3, [%rd22];
    cvt.rn.f32.s32 %f4, %r27;
    mul.rn.f32 %f5, %f2, %f3;
    fma.rn.f32 %f1, %f4, %f5, %f1;

Q40S_REDUCE:
    mov.b32 %r28, %f1;
    shfl.sync.down.b32 %r29, %r28, 16, 31, 0xffffffff;
    mov.b32 %f6, %r29; add.f32 %f1, %f1, %f6; mov.b32 %r28, %f1;
    shfl.sync.down.b32 %r29, %r28, 8, 31, 0xffffffff;
    mov.b32 %f6, %r29; add.f32 %f1, %f1, %f6; mov.b32 %r28, %f1;
    shfl.sync.down.b32 %r29, %r28, 4, 31, 0xffffffff;
    mov.b32 %f6, %r29; add.f32 %f1, %f1, %f6; mov.b32 %r28, %f1;
    shfl.sync.down.b32 %r29, %r28, 2, 31, 0xffffffff;
    mov.b32 %f6, %r29; add.f32 %f1, %f1, %f6; mov.b32 %r28, %f1;
    shfl.sync.down.b32 %r29, %r28, 1, 31, 0xffffffff;
    mov.b32 %f6, %r29; add.f32 %f1, %f1, %f6;

    setp.ne.u32 %p4, %r5, 0;             // only lane 0 writes
    @%p4 bra Q40S_DONE;
    mul.wide.u32 %rd30, %r9, 4;
    add.s64 %rd31, %rd5, %rd30;
    cvta.to.global.u64 %rd31, %rd31;
    st.global.f32 [%rd31], %f1;

Q40S_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_gemv_q6_k_soa: y = W @ x, Q6_K weights in STRUCTURE-OF-ARRAYS layout
// (M2.2 Task C-1 - the precision-first 6.5625 bpw decode kernel; replaces
// the load-time Q6_K -> Q8_0 requant that streamed these tensors at 8.5).
//
//   p_wql : low 4 bits [out_dim * in_dim / 2] (u8), repack-linearized out
//           of ggml's half/quarter interleave, packed in the shared kernel
//           order (u32 = 8 consecutive values as lo/hi nibble halves).
//   p_wqh : upper 2-bit fields [out_dim * in_dim / 2] (u8) in the IDENTICAL
//           nibble layout as ql (WIDENED from ggml's 64 B/super-block to
//           128 B - see repack::q6_k_to_soa for the bytes-vs-ALU trade):
//           one coalesced u32 load per 8 values, reconstructed with a
//           nibble mask + shl instead of a 32-op per-byte 2-bit spread.
//   p_wsc : VERBATIM i8 sub-block scales [out_dim * in_dim/16].
//   p_wd  : VERBATIM f16 super-block scales [out_dim * in_dim/256].
//   p_xqs / p_xsc : int8 activation + f32 block scales (gl_quantize_q8).
//   p_y   : f32 output [out_dim].
//
// Math per 16-weight sub-block:  w_i = d*sc*(q6_i - 32),  x_i = xs*xq_i
//   sum w_i*x_i = d*sc*xs * (dot(q6, xq) - 32*sum(xq))
// A lane's 8 values sit inside ONE sub-block (lane l owns values 8l..8l+8,
// sub-block l/2) and one activation block (xs at l/4), so the identity
// holds per lane with scalar sc/xs. q6 = ql | (qh_field << 4) is assembled
// in registers into int8x4 lanes (0..63, safely positive s8); the -32
// centering folds into the integer domain like Q4_0's -8.
//
// One warp per output row, one iteration per 256-value super-block:
// 128 B ql + 128 B qh + 16 B sc + 2 B d = 274 B of weight stream per
// iteration (7.0625 bpw). in_dim % 256 == 0 is a Q6_K format invariant.
// Launch: grid ceil(out_dim / (ntid/32)) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_gemv_q6_k_soa(
    .param .u64 p_wql,
    .param .u64 p_wqh,
    .param .u64 p_wsc,
    .param .u64 p_wd,
    .param .u64 p_xqs,
    .param .u64 p_xsc,
    .param .u64 p_y,
    .param .u32 p_out,
    .param .u32 p_in
)
{
    .reg .pred %p<5>;
    .reg .b16 %h<3>;
    .reg .b32 %r<44>;
    .reg .f32 %f<14>;
    .reg .b64 %rd<44>;

    ld.param.u64 %rd1, [p_wql];
    ld.param.u64 %rd2, [p_wqh];
    ld.param.u64 %rd3, [p_wsc];
    ld.param.u64 %rd4, [p_wd];
    ld.param.u64 %rd5, [p_xqs];
    ld.param.u64 %rd6, [p_xsc];
    ld.param.u64 %rd7, [p_y];
    ld.param.u32 %r1, [p_out];
    ld.param.u32 %r2, [p_in];

    mov.u32 %r3, %tid.x;
    shr.u32 %r4, %r3, 5;                 // warp_id
    and.b32 %r5, %r3, 31;                // lane
    mov.u32 %r6, %ntid.x;
    shr.u32 %r7, %r6, 5;                 // warps per block
    mov.u32 %r8, %ctaid.x;
    mad.lo.s32 %r9, %r8, %r7, %r4;       // output row
    setp.ge.u32 %p1, %r9, %r1;
    @%p1 bra Q6K_DONE;

    cvta.to.global.u64 %rd8, %rd1;
    cvta.to.global.u64 %rd9, %rd2;
    cvta.to.global.u64 %rd10, %rd3;
    cvta.to.global.u64 %rd11, %rd4;
    cvta.to.global.u64 %rd12, %rd5;
    cvta.to.global.u64 %rd13, %rd6;

    shr.u32 %r10, %r2, 8;                // n_sb = in / 256 super-blocks
    shr.u32 %r11, %r2, 1;                // ql/qh row bytes = in / 2 (qh widened)
    shr.u32 %r13, %r2, 4;                // sc row bytes = in / 16

    // Row bases.
    mul.wide.u32 %rd14, %r9, %r11;
    add.s64 %rd15, %rd8, %rd14;          // ql row base
    add.s64 %rd17, %rd9, %rd14;          // qh row base (same stride as ql)
    mul.wide.u32 %rd18, %r9, %r13;
    add.s64 %rd19, %rd10, %rd18;         // sc row base
    mul.wide.u32 %rd20, %r9, %r10;
    shl.b64 %rd20, %rd20, 1;             // f16 per super-block
    add.s64 %rd21, %rd11, %rd20;         // d row base

    // Lane offsets: lane l owns values 8l..8l+8 = sub-block l/2, act block l/4.
    shl.b32 %r14, %r5, 2;                // lane * 4
    cvt.u64.u32 %rd22, %r14;
    add.s64 %rd23, %rd15, %rd22;         // ql lane ptr (u32)
    add.s64 %rd25, %rd17, %rd22;         // qh lane ptr (u32, same layout as ql)
    shr.u32 %r16, %r5, 1;                // sub-block = lane / 2 (0..15)
    cvt.u64.u32 %rd26, %r16;
    add.s64 %rd27, %rd19, %rd26;         // sc lane ptr (s8)
    shl.b32 %r17, %r5, 3;                // lane * 8
    cvt.u64.u32 %rd28, %r17;
    add.s64 %rd29, %rd12, %rd28;         // xqs lane ptr
    shr.u32 %r18, %r5, 2;                // act block = lane / 4 (0..7)
    cvt.u64.u32 %rd30, %r18;
    shl.b64 %rd31, %rd30, 2;
    add.s64 %rd32, %rd13, %rd31;         // xsc lane ptr (f32)

    mov.f32 %f1, 0f00000000;             // FP32 accumulator
    mov.u32 %r19, 0x01010101;            // dp4a "ones"
    mov.u32 %r20, 0;                     // super-block index

Q6K_LOOP:
    setp.ge.u32 %p2, %r20, %r10;
    @%p2 bra Q6K_REDUCE;

    // ql and qh share the same u32-per-8-values packing (repack tuning):
    // a single coalesced u32 each, reconstructed with one and/shl/or per
    // int8x4 half instead of the old 32-op per-byte 2-bit spread. qh holds
    // the raw 2-bit fields in nibble slots (0..3), so (qh_field << 4) | ql
    // is the assembled 6-bit value (0..63).
    ld.global.u32 %r21, [%rd23];         // ql: 8 low nibbles
    and.b32 %r22, %r21, 0x0F0F0F0F;      // low4 of values 8g..8g+4
    shr.u32 %r23, %r21, 4;
    and.b32 %r23, %r23, 0x0F0F0F0F;      // low4 of values 8g+4..8g+8
    ld.global.u32 %r24, [%rd25];         // qh: 8 high-2-bit fields (nibbles)
    and.b32 %r25, %r24, 0x0F0F0F0F;      // 2-bit fields of 8g..8g+4
    shl.b32 %r25, %r25, 4;               // -> bit 4 of each int8 lane
    shr.u32 %r26, %r24, 4;
    and.b32 %r26, %r26, 0x0F0F0F0F;
    shl.b32 %r26, %r26, 4;               // 2-bit fields of 8g+4..8g+8

    or.b32 %r29, %r22, %r25;             // q6 values 8g..8g+4 (0..63)
    or.b32 %r30, %r23, %r26;             // q6 values 8g+4..8g+8

    ld.global.u32 %r31, [%rd29];         // xq bytes 0..3
    ld.global.u32 %r32, [%rd29+4];       // xq bytes 4..7
    dp4a.s32.s32 %r33, %r29, %r31, 0;
    dp4a.s32.s32 %r33, %r30, %r32, %r33; // idot = dot(q6, xq)
    dp4a.s32.s32 %r34, %r31, %r19, 0;
    dp4a.s32.s32 %r34, %r32, %r19, %r34; // isum = sum(xq)
    shl.b32 %r35, %r34, 5;               // 32 * isum
    sub.s32 %r36, %r33, %r35;            // idot - 32*isum (exact)

    ld.global.s8 %r37, [%rd27];          // sc (i8, sign-extended)
    cvt.rn.f32.s32 %f2, %r37;
    ld.global.u16 %h1, [%rd21];
    cvt.f32.f16 %f3, %h1;                // d (f16 super-block scale)
    ld.global.f32 %f4, [%rd32];          // xs
    cvt.rn.f32.s32 %f5, %r36;
    mul.rn.f32 %f6, %f3, %f2;            // d * sc
    mul.rn.f32 %f7, %f6, %f4;            // * xs
    fma.rn.f32 %f1, %f5, %f7, %f1;

    add.s64 %rd23, %rd23, 128;           // ql: 128 B / super-block
    add.s64 %rd25, %rd25, 128;           // qh: 128 B (widened nibble slots)
    add.s64 %rd27, %rd27, 16;            // sc: 16 B
    add.s64 %rd21, %rd21, 2;             // d: 2 B
    add.s64 %rd29, %rd29, 256;           // xq: 256 B
    add.s64 %rd32, %rd32, 32;            // xsc: 8 f32
    add.s32 %r20, %r20, 1;
    bra Q6K_LOOP;

Q6K_REDUCE:
    mov.b32 %r40, %f1;
    shfl.sync.down.b32 %r41, %r40, 16, 31, 0xffffffff;
    mov.b32 %f9, %r41; add.f32 %f1, %f1, %f9; mov.b32 %r40, %f1;
    shfl.sync.down.b32 %r41, %r40, 8, 31, 0xffffffff;
    mov.b32 %f9, %r41; add.f32 %f1, %f1, %f9; mov.b32 %r40, %f1;
    shfl.sync.down.b32 %r41, %r40, 4, 31, 0xffffffff;
    mov.b32 %f9, %r41; add.f32 %f1, %f1, %f9; mov.b32 %r40, %f1;
    shfl.sync.down.b32 %r41, %r40, 2, 31, 0xffffffff;
    mov.b32 %f9, %r41; add.f32 %f1, %f1, %f9; mov.b32 %r40, %f1;
    shfl.sync.down.b32 %r41, %r40, 1, 31, 0xffffffff;
    mov.b32 %f9, %r41; add.f32 %f1, %f1, %f9;

    setp.ne.u32 %p3, %r5, 0;             // only lane 0 writes
    @%p3 bra Q6K_DONE;
    mul.wide.u32 %rd40, %r9, 4;
    add.s64 %rd41, %rd7, %rd40;
    cvta.to.global.u64 %rd41, %rd41;
    st.global.f32 [%rd41], %f1;

Q6K_DONE:
    ret;
}

// ===========================================================================
// M2.3 Stage 1b - batched-over-tokens ("rows") variants for prefill.
//
// The prefill chunk used to launch the per-token kernels in a serial loop
// (~7000 launches per 32-token chunk, each a few us of latency on a chain
// of dependencies). These variants add a token dimension (ctaid.y = row)
// so one launch covers the whole chunk. They read positions from the
// pos_seq identity array (pos_seq[p] == p, uploaded once at load):
// row t uses pos = pos_seq[base + t], and cached_len = pos + 1.
//
// The single-token originals are kept untouched - the decode graph is
// captured against them and their launch geometry is token-invariant.
// Same math, same rounding, same order as the originals.
// ===========================================================================

// ---------------------------------------------------------------------------
// gl_rms_norm_rows_f32: out[r][i] = x[r][i] * rsqrt(mean(x[r]^2)+eps) * w[i]
// for rows r = 0..gridDim.x. Exactly gl_rms_norm_f32 per block, with the
// block's row selected by ctaid.x. Launch: grid (rows) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_rms_norm_rows_f32(
    .param .u64 p_x,
    .param .u64 p_w,
    .param .u64 p_out,
    .param .u32 p_dim,
    .param .f32 p_eps
)
{
    .reg .pred %p<8>;
    .reg .b32 %r<24>;
    .reg .f32 %f<20>;
    .reg .b64 %rd<24>;
    .shared .align 4 .b8 sm_rmsr[36];

    ld.param.u64 %rd1, [p_x];
    ld.param.u64 %rd2, [p_w];
    ld.param.u64 %rd3, [p_out];
    ld.param.u32 %r1, [p_dim];
    ld.param.f32 %f1, [p_eps];
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    // Row base: this block handles row ctaid.x of x/out (w is shared).
    mov.u32 %r18, %ctaid.x;
    mul.lo.s32 %r19, %r18, %r1;
    mul.wide.u32 %rd14, %r19, 4;
    add.s64 %rd4, %rd4, %rd14;
    add.s64 %rd6, %rd6, %rd14;
    mov.u32 %r2, %tid.x;
    mov.u32 %r3, %ntid.x;
    and.b32 %r5, %r2, 31;               // lane
    shr.u32 %r6, %r2, 5;                // warp id
    mov.u32 %r7, sm_rmsr;               // shared base
    add.s32 %r10, %r3, 31;
    shr.u32 %r11, %r10, 5;              // n_warps

    // strided sum of squares
    mov.f32 %f2, 0f00000000;
    mov.u32 %r4, %r2;
    mul.wide.u32 %rd7, %r2, 4;
    add.s64 %rd8, %rd4, %rd7;           // x ptr
    mul.wide.u32 %rd9, %r3, 4;          // stride bytes
RMSR_ACC:
    setp.ge.u32 %p1, %r4, %r1;
    @%p1 bra RMSR_WARP_RED;
    ld.global.f32 %f3, [%rd8];
    fma.rn.f32 %f2, %f3, %f3, %f2;
    add.s32 %r4, %r4, %r3;
    add.s64 %rd8, %rd8, %rd9;
    bra RMSR_ACC;
RMSR_WARP_RED:
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 16, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 8, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 4, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 2, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    mov.b32 %r16, %f2;
    shfl.sync.down.b32 %r17, %r16, 1, 31, 0xffffffff;
    mov.b32 %f4, %r17;
    add.f32 %f2, %f2, %f4;
    setp.ne.u32 %p2, %r5, 0;
    @%p2 bra RMSR_BARRIER1;
    shl.b32 %r8, %r6, 2;
    add.s32 %r9, %r7, %r8;
    st.shared.f32 [%r9], %f2;
RMSR_BARRIER1:
    bar.sync 0;
    setp.ne.u32 %p3, %r2, 0;
    @%p3 bra RMSR_BCAST;
    mov.f32 %f5, 0f00000000;
    mov.u32 %r12, 0;
RMSR_SUM_WARPS:
    setp.ge.u32 %p4, %r12, %r11;
    @%p4 bra RMSR_FINISH;
    shl.b32 %r13, %r12, 2;
    add.s32 %r14, %r7, %r13;
    ld.shared.f32 %f6, [%r14];
    add.f32 %f5, %f5, %f6;
    add.s32 %r12, %r12, 1;
    bra RMSR_SUM_WARPS;
RMSR_FINISH:
    cvt.rn.f32.u32 %f7, %r1;
    div.rn.f32 %f8, %f5, %f7;
    add.f32 %f9, %f8, %f1;
    sqrt.rn.f32 %f10, %f9;
    rcp.rn.f32 %f11, %f10;
    st.shared.f32 [%r7+32], %f11;
RMSR_BCAST:
    bar.sync 0;
    ld.shared.f32 %f12, [%r7+32];
    mov.u32 %r15, %r2;
    mul.wide.u32 %rd10, %r2, 4;
    add.s64 %rd11, %rd4, %rd10;
    add.s64 %rd12, %rd5, %rd10;
    add.s64 %rd13, %rd6, %rd10;
RMSR_OUT:
    setp.ge.u32 %p5, %r15, %r1;
    @%p5 bra RMSR_DONE;
    ld.global.f32 %f13, [%rd11];
    ld.global.f32 %f14, [%rd12];
    mul.rn.f32 %f15, %f13, %f12;
    mul.rn.f32 %f16, %f15, %f14;
    st.global.f32 [%rd13], %f16;
    add.s32 %r15, %r15, %r3;
    add.s64 %rd11, %rd11, %rd9;
    add.s64 %rd12, %rd12, %rd9;
    add.s64 %rd13, %rd13, %rd9;
    bra RMSR_OUT;
RMSR_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_add_bias_rows_f32: y[i] += b[i % dim] for i < total - the broadcast
// bias add over a [rows, dim] activation block in one launch (the per-token
// loop was up to 3 * n_layers * n launches per chunk on biased models).
// Launch: grid ceil(total/256) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_add_bias_rows_f32(
    .param .u64 p_y,
    .param .u64 p_b,
    .param .u32 p_dim,
    .param .u32 p_total
)
{
    .reg .pred %p<2>;
    .reg .b32 %r<10>;
    .reg .f32 %f<4>;
    .reg .b64 %rd<10>;

    ld.param.u64 %rd1, [p_y];
    ld.param.u64 %rd2, [p_b];
    ld.param.u32 %r1, [p_dim];
    ld.param.u32 %r2, [p_total];
    mov.u32 %r3, %ctaid.x;
    mov.u32 %r4, %ntid.x;
    mov.u32 %r5, %tid.x;
    mad.lo.s32 %r6, %r3, %r4, %r5;
    setp.ge.u32 %p1, %r6, %r2;
    @%p1 bra ABR_DONE;
    cvta.to.global.u64 %rd3, %rd1;
    cvta.to.global.u64 %rd4, %rd2;
    rem.u32 %r7, %r6, %r1;              // bias index = i % dim
    mul.wide.u32 %rd5, %r6, 4;
    add.s64 %rd6, %rd3, %rd5;
    mul.wide.u32 %rd7, %r7, 4;
    add.s64 %rd8, %rd4, %rd7;
    ld.global.f32 %f1, [%rd6];
    ld.global.f32 %f2, [%rd8];
    add.f32 %f3, %f1, %f2;
    st.global.f32 [%rd6], %f3;
ABR_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_rope_rows_f32: gl_rope_f32 over ctaid.y token rows in one launch.
// Row t rotates x + t*(n_heads*head_dim) at position pos_seq[t] (the caller
// passes p_pos_seq already offset to the chunk base, so element t IS the
// row's absolute position). Launch: grid (ceil(pairs/256), ntok) x 256.
// ---------------------------------------------------------------------------
.visible .entry gl_rope_rows_f32(
    .param .u64 p_x,
    .param .u64 p_cos,
    .param .u64 p_sin,
    .param .u32 p_heads,
    .param .u32 p_head_dim,
    .param .u32 p_neox,
    .param .u64 p_pos_seq
)
{
    .reg .pred %p<3>;
    .reg .b32 %r<26>;
    .reg .f32 %f<12>;
    .reg .b64 %rd<20>;

    ld.param.u64 %rd1, [p_x];
    ld.param.u64 %rd2, [p_cos];
    ld.param.u64 %rd3, [p_sin];
    ld.param.u32 %r1, [p_heads];
    ld.param.u32 %r2, [p_head_dim];
    ld.param.u32 %r3, [p_neox];
    ld.param.u64 %rd14, [p_pos_seq];
    shr.u32 %r4, %r2, 1;                // half = head_dim / 2
    mov.u32 %r5, %ctaid.x;
    mov.u32 %r6, %ntid.x;
    mov.u32 %r7, %tid.x;
    mad.lo.s32 %r8, %r5, %r6, %r7;      // pair index
    mul.lo.s32 %r9, %r1, %r4;           // total pairs
    setp.ge.u32 %p1, %r8, %r9;
    @%p1 bra ROPER_DONE;
    div.u32 %r10, %r8, %r4;             // h
    rem.u32 %r11, %r8, %r4;             // i
    mul.lo.s32 %r12, %r10, %r2;         // base = h * head_dim
    setp.ne.u32 %p2, %r3, 0;
    @%p2 bra ROPER_NEOX;
    shl.b32 %r13, %r11, 1;
    add.s32 %r14, %r12, %r13;           // a = base + 2i
    add.s32 %r15, %r14, 1;              // b = a + 1
    bra ROPER_IDX_DONE;
ROPER_NEOX:
    add.s32 %r14, %r12, %r11;           // a = base + i
    add.s32 %r15, %r14, %r4;            // b = a + half
ROPER_IDX_DONE:
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    // Row t: x base += t * heads*head_dim; pos = pos_seq[t].
    mov.u32 %r20, %ctaid.y;
    mul.lo.s32 %r21, %r1, %r2;          // heads * head_dim
    mul.lo.s32 %r22, %r21, %r20;        // row element offset
    mul.wide.u32 %rd16, %r22, 4;
    add.s64 %rd4, %rd4, %rd16;
    cvta.to.global.u64 %rd15, %rd14;
    mul.wide.u32 %rd17, %r20, 4;
    add.s64 %rd15, %rd15, %rd17;
    ld.global.u32 %r16, [%rd15];        // pos = pos_seq[t]
    mul.lo.s32 %r17, %r16, %r4;         // pos * half
    add.s32 %r18, %r17, %r11;           // pos*half + i
    mul.wide.u32 %rd7, %r18, 4;
    add.s64 %rd8, %rd5, %rd7;
    add.s64 %rd9, %rd6, %rd7;
    ld.global.f32 %f1, [%rd8];          // cos
    ld.global.f32 %f2, [%rd9];          // sin
    mul.wide.u32 %rd10, %r14, 4;
    add.s64 %rd11, %rd4, %rd10;
    mul.wide.u32 %rd12, %r15, 4;
    add.s64 %rd13, %rd4, %rd12;
    ld.global.f32 %f3, [%rd11];         // x0
    ld.global.f32 %f4, [%rd13];         // x1
    mul.f32 %f5, %f3, %f1;
    mul.f32 %f6, %f4, %f2;
    sub.f32 %f7, %f5, %f6;              // x0*cos - x1*sin
    mul.f32 %f8, %f3, %f2;
    mul.f32 %f9, %f4, %f1;
    add.f32 %f10, %f8, %f9;             // x0*sin + x1*cos
    st.global.f32 [%rd11], %f7;
    st.global.f32 [%rd13], %f10;
ROPER_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_kv_write_rows: gl_kv_write over ctaid.y token rows in one launch. Row t
// copies src + t*(n_kv*head_dim) into cache position pos_seq[t].
// Launch: grid (ceil(n_kv*head_dim/256), ntok) x 256 threads.
// ---------------------------------------------------------------------------
.visible .entry gl_kv_write_rows(
    .param .u64 p_dst,
    .param .u64 p_src,
    .param .u64 p_pos_seq,
    .param .u32 p_head_dim,
    .param .u32 p_n_kv,
    .param .u32 p_head_stride
)
{
    .reg .pred %p<2>;
    .reg .b32 %r<20>;
    .reg .f32 %f<2>;
    .reg .b64 %rd<20>;

    ld.param.u64 %rd1, [p_dst];
    ld.param.u64 %rd2, [p_src];
    ld.param.u64 %rd3, [p_pos_seq];
    ld.param.u32 %r1, [p_head_dim];
    ld.param.u32 %r2, [p_n_kv];
    ld.param.u32 %r3, [p_head_stride];
    mov.u32 %r4, %ctaid.x;
    mov.u32 %r5, %ntid.x;
    mov.u32 %r6, %tid.x;
    mad.lo.s32 %r7, %r4, %r5, %r6;       // e = element index within a row
    mul.lo.s32 %r8, %r2, %r1;            // n_kv * head_dim
    setp.ge.u32 %p1, %r7, %r8;
    @%p1 bra KVWR_DONE;
    cvta.to.global.u64 %rd4, %rd1;
    cvta.to.global.u64 %rd5, %rd2;
    cvta.to.global.u64 %rd6, %rd3;
    // Row t: src base += t * n_kv*head_dim; pos = pos_seq[t].
    mov.u32 %r16, %ctaid.y;
    mul.lo.s32 %r17, %r8, %r16;
    mul.wide.u32 %rd11, %r17, 4;
    add.s64 %rd5, %rd5, %rd11;
    mul.wide.u32 %rd12, %r16, 4;
    add.s64 %rd6, %rd6, %rd12;
    ld.global.u32 %r9, [%rd6];           // pos
    div.u32 %r10, %r7, %r1;              // kv_head
    rem.u32 %r11, %r7, %r1;              // d
    mul.lo.s32 %r12, %r10, %r3;          // kv_head * head_stride
    mul.lo.s32 %r13, %r9, %r1;           // pos * head_dim
    add.s32 %r14, %r12, %r13;
    add.s32 %r15, %r14, %r11;            // dst element index
    mul.wide.u32 %rd7, %r7, 4;
    add.s64 %rd8, %rd5, %rd7;
    ld.global.f32 %f1, [%rd8];
    mul.wide.u32 %rd9, %r15, 4;
    add.s64 %rd10, %rd4, %rd9;
    st.global.f32 [%rd10], %f1;
KVWR_DONE:
    ret;
}

// ---------------------------------------------------------------------------
// gl_attn_decode_rows_f32: gl_attn_decode_f32 over ctaid.y token rows in one
// launch - the whole chunk's causal attention per layer. Block (h, t) runs
// query head h of token row t: q/out at + t*(n_heads*head_dim), and
// cached_len = pos_seq[t] + 1, so row t attends to exactly the first
// pos_seq[t]+1 cache rows (its own KV row was written by the preceding
// gl_kv_write_rows launch; later rows exist but are never read - causal).
// Launch: grid (n_heads, ntok) x 128 threads. Same shared plan as the
// original (16 KiB scores + 36 B reduction scratch).
// ---------------------------------------------------------------------------
.visible .entry gl_attn_decode_rows_f32(
    .param .u64 p_q,
    .param .u64 p_k,
    .param .u64 p_v,
    .param .u64 p_out,
    .param .u32 p_head_dim,
    .param .u64 p_pos_seq,
    .param .u32 p_heads_per_kv,
    .param .u32 p_head_stride,
    .param .f32 p_scale
)
{
    .reg .pred %p<8>;
    .reg .b32 %r<48>;
    .reg .f32 %f<32>;
    .reg .b64 %rd<44>;
    .shared .align 4 .b8 sm_scr[16384];  // scores[0..4096]
    .shared .align 4 .b8 sm_redr[36];    // warp partials + broadcast

    ld.param.u64 %rd1, [p_q];
    ld.param.u64 %rd2, [p_k];
    ld.param.u64 %rd3, [p_v];
    ld.param.u64 %rd4, [p_out];
    ld.param.u32 %r1, [p_head_dim];
    ld.param.u64 %rd30, [p_pos_seq];
    ld.param.u32 %r3, [p_heads_per_kv];
    ld.param.u32 %r4, [p_head_stride];
    ld.param.f32 %f1, [p_scale];

    // Token row t and its causal length: cached_len = pos_seq[t] + 1.
    mov.u32 %r42, %ctaid.y;
    cvta.to.global.u64 %rd31, %rd30;
    mul.wide.u32 %rd32, %r42, 4;
    add.s64 %rd31, %rd31, %rd32;
    ld.global.u32 %r2, [%rd31];          // pos
    add.s32 %r2, %r2, 1;                 // cached_len

    mov.u32 %r5, %ctaid.x;               // h (query head)
    mov.u32 %r6, %tid.x;                 // thread id
    mov.u32 %r7, %ntid.x;                // block size
    and.b32 %r8, %r6, 31;                // lane
    shr.u32 %r9, %r6, 5;                 // warp id
    add.s32 %r10, %r7, 31;
    shr.u32 %r11, %r10, 5;               // n_warps
    mov.u32 %r12, sm_scr;                // scores base (shared)
    mov.u32 %r13, sm_redr;               // reduction base (shared)

    cvta.to.global.u64 %rd5, %rd1;       // q global
    cvta.to.global.u64 %rd6, %rd2;       // k global
    cvta.to.global.u64 %rd7, %rd3;       // v global
    cvta.to.global.u64 %rd8, %rd4;       // out global

    // Row bases: q/out += t * n_heads*head_dim (n_heads = gridDim.x).
    mov.u32 %r43, %nctaid.x;
    mul.lo.s32 %r44, %r43, %r1;
    mul.lo.s32 %r45, %r44, %r42;
    mul.wide.u32 %rd33, %r45, 4;
    add.s64 %rd5, %rd5, %rd33;
    add.s64 %rd8, %rd8, %rd33;

    // kv_head = h / heads_per_kv ; kv offset in elements = kv_head*head_stride
    div.u32 %r14, %r5, %r3;              // kv_head
    mul.lo.s32 %r15, %r14, %r4;          // kv_head * head_stride (elems)
    mul.wide.u32 %rd9, %r15, 4;
    add.s64 %rd10, %rd6, %rd9;           // k_base for this head
    add.s64 %rd11, %rd7, %rd9;           // v_base for this head
    // q vector base = q + h*head_dim
    mul.lo.s32 %r16, %r5, %r1;
    mul.wide.u32 %rd12, %r16, 4;
    add.s64 %rd13, %rd5, %rd12;          // q_base
    add.s64 %rd14, %rd8, %rd12;          // out_base

    // ---- Pass 1: scores[t] = (q . k[t]) * scale, one thread per t ----
    mov.u32 %r17, %r6;                   // t = tid
ATTNR_SCORE:
    setp.ge.u32 %p1, %r17, %r2;
    @%p1 bra ATTNR_SCORE_DONE;
    mul.lo.s32 %r18, %r17, %r1;
    mul.wide.u32 %rd15, %r18, 4;
    add.s64 %rd16, %rd10, %rd15;         // &k[t][0]
    mov.u64 %rd17, %rd13;                // &q[0]
    mov.f32 %f2, 0f00000000;             // dot acc (FP32)
    mov.u32 %r19, 0;                     // d
ATTNR_DOT:
    setp.ge.u32 %p2, %r19, %r1;
    @%p2 bra ATTNR_DOT_DONE;
    ld.global.f32 %f3, [%rd17];
    ld.global.f32 %f4, [%rd16];
    fma.rn.f32 %f2, %f3, %f4, %f2;
    add.s64 %rd17, %rd17, 4;
    add.s64 %rd16, %rd16, 4;
    add.s32 %r19, %r19, 1;
    bra ATTNR_DOT;
ATTNR_DOT_DONE:
    mul.rn.f32 %f2, %f2, %f1;            // * scale
    shl.b32 %r20, %r17, 2;
    add.s32 %r21, %r12, %r20;
    st.shared.f32 [%r21], %f2;
    add.s32 %r17, %r17, %r7;             // t += blockDim
    bra ATTNR_SCORE;
ATTNR_SCORE_DONE:
    bar.sync 0;

    // ---- Pass 2: softmax over sm_scr[0..cached_len] ----
    mov.f32 %f5, 0fFF800000;             // -inf
    mov.u32 %r22, %r6;
ATTNR_MAX:
    setp.ge.u32 %p3, %r22, %r2;
    @%p3 bra ATTNR_MAX_RED;
    shl.b32 %r23, %r22, 2;
    add.s32 %r24, %r12, %r23;
    ld.shared.f32 %f6, [%r24];
    max.f32 %f5, %f5, %f6;
    add.s32 %r22, %r22, %r7;
    bra ATTNR_MAX;
ATTNR_MAX_RED:
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 16, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 8, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 4, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 2, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    mov.b32 %r25, %f5;
    shfl.sync.down.b32 %r26, %r25, 1, 31, 0xffffffff;
    mov.b32 %f6, %r26;
    max.f32 %f5, %f5, %f6;
    setp.ne.u32 %p4, %r8, 0;
    @%p4 bra ATTNR_MAX_BAR;
    shl.b32 %r27, %r9, 2;
    add.s32 %r28, %r13, %r27;
    st.shared.f32 [%r28], %f5;
ATTNR_MAX_BAR:
    bar.sync 0;
    setp.ne.u32 %p5, %r6, 0;
    @%p5 bra ATTNR_MAX_BC;
    mov.f32 %f7, 0fFF800000;
    mov.u32 %r29, 0;
ATTNR_MAX_W:
    setp.ge.u32 %p6, %r29, %r11;
    @%p6 bra ATTNR_MAX_ST;
    shl.b32 %r30, %r29, 2;
    add.s32 %r31, %r13, %r30;
    ld.shared.f32 %f8, [%r31];
    max.f32 %f7, %f7, %f8;
    add.s32 %r29, %r29, 1;
    bra ATTNR_MAX_W;
ATTNR_MAX_ST:
    st.shared.f32 [%r13+32], %f7;
ATTNR_MAX_BC:
    bar.sync 0;
    ld.shared.f32 %f9, [%r13+32];        // m (block max), uniform

    mov.f32 %f10, 0f00000000;            // sum acc
    mov.u32 %r32, %r6;
ATTNR_EXP:
    setp.ge.u32 %p3, %r32, %r2;
    @%p3 bra ATTNR_SUM_RED;
    shl.b32 %r33, %r32, 2;
    add.s32 %r34, %r12, %r33;
    ld.shared.f32 %f11, [%r34];
    sub.f32 %f12, %f11, %f9;             // score - m
    mul.f32 %f13, %f12, 0f3FB8AA3B;      // * log2(e)
    ex2.approx.f32 %f14, %f13;           // exp(score - m)
    st.shared.f32 [%r34], %f14;
    add.f32 %f10, %f10, %f14;
    add.s32 %r32, %r32, %r7;
    bra ATTNR_EXP;
ATTNR_SUM_RED:
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 16, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 8, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 4, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 2, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    mov.b32 %r25, %f10;
    shfl.sync.down.b32 %r26, %r25, 1, 31, 0xffffffff;
    mov.b32 %f11, %r26;
    add.f32 %f10, %f10, %f11;
    setp.ne.u32 %p4, %r8, 0;
    @%p4 bra ATTNR_SUM_BAR;
    shl.b32 %r27, %r9, 2;
    add.s32 %r28, %r13, %r27;
    st.shared.f32 [%r28], %f10;
ATTNR_SUM_BAR:
    bar.sync 0;
    setp.ne.u32 %p5, %r6, 0;
    @%p5 bra ATTNR_SUM_BC;
    mov.f32 %f15, 0f00000000;
    mov.u32 %r29, 0;
ATTNR_SUM_W:
    setp.ge.u32 %p6, %r29, %r11;
    @%p6 bra ATTNR_SUM_ST;
    shl.b32 %r30, %r29, 2;
    add.s32 %r31, %r13, %r30;
    ld.shared.f32 %f16, [%r31];
    add.f32 %f15, %f15, %f16;
    add.s32 %r29, %r29, 1;
    bra ATTNR_SUM_W;
ATTNR_SUM_ST:
    st.shared.f32 [%r13+32], %f15;
ATTNR_SUM_BC:
    bar.sync 0;
    ld.shared.f32 %f17, [%r13+32];       // sum, uniform
    setp.gt.f32 %p7, %f17, 0f00000000;
    mov.f32 %f18, 0f3F800000;            // 1.0 default (no-op divide)
    @!%p7 bra ATTNR_RCP_DONE;
    rcp.rn.f32 %f18, %f17;               // 1/sum
ATTNR_RCP_DONE:
    bar.sync 0;

    // ---- Pass 3: out[d] = sum_t (scores[t]*inv_sum) * v[t][d] ----
    mov.u32 %r35, %r6;                   // d = tid
ATTNR_OUT:
    setp.ge.u32 %p1, %r35, %r1;
    @%p1 bra ATTNR_OUT_DONE;
    mov.f32 %f19, 0f00000000;            // out acc
    mov.u32 %r36, 0;                     // t
    mul.wide.u32 %rd18, %r35, 4;
    add.s64 %rd19, %rd11, %rd18;         // &v[0][d]
    mul.lo.s32 %r37, %r1, 4;             // row stride bytes
    cvt.u64.u32 %rd20, %r37;
ATTNR_OUT_LOOP:
    setp.ge.u32 %p2, %r36, %r2;
    @%p2 bra ATTNR_OUT_STORE;
    shl.b32 %r38, %r36, 2;
    add.s32 %r39, %r12, %r38;
    ld.shared.f32 %f20, [%r39];          // exp weight (un-normalized)
    mul.rn.f32 %f21, %f20, %f18;         // * inv_sum -> normalized weight
    ld.global.f32 %f22, [%rd19];         // v[t][d]
    fma.rn.f32 %f19, %f21, %f22, %f19;
    add.s64 %rd19, %rd19, %rd20;
    add.s32 %r36, %r36, 1;
    bra ATTNR_OUT_LOOP;
ATTNR_OUT_STORE:
    add.s64 %rd21, %rd14, %rd18;
    st.global.f32 [%rd21], %f19;
    add.s32 %r35, %r35, %r7;
    bra ATTNR_OUT;
ATTNR_OUT_DONE:
    ret;
}
